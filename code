class HUDRenderer:
    """
    Renders the Heads-Up Display overlay including:
    - Race position indicators
    - Character names and positions
    - Countdown
    - Winner announcement
    - Progress bars
    - Speed indicators
    """

    def __init__(self, config: MasterConfig):
        self.config = config
        self.vc = config.video
        self.font_cache: Dict[int, ImageFont.FreeTypeFont] = {}

    def _get_font(self, size: int) -> ImageFont.FreeTypeFont:
        """Get or create a font at the given size."""
        if size not in self.font_cache:
            try:
                # Try to find a system font
                for font_path in [
                    "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
                    "/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf",
                    "/usr/share/fonts/truetype/ubuntu/Ubuntu-Bold.ttf",
                ]:
                    if os.path.exists(font_path):
                        self.font_cache[size] = ImageFont.truetype(font_path, size)
                        return self.font_cache[size]
                # Fallback
                self.font_cache[size] = ImageFont.load_default()
            except Exception:
                self.font_cache[size] = ImageFont.load_default()
        return self.font_cache[size]

    def render_countdown(
        self, img: Image.Image, countdown_value: int, phase_progress: float
    ) -> Image.Image:
        """Render countdown overlay (3, 2, 1, GO!)."""
        draw = ImageDraw.Draw(img)
        w, h = img.size

        if countdown_value > 0:
            text = str(countdown_value)
        else:
            text = "GO!"

        # Pulsing scale effect
        pulse = abs(math.sin(phase_progress * math.pi * 4)) * 0.3 + 0.7
        font_size = int(180 * pulse)
        font = self._get_font(font_size)

        # Get text bounding box
        bbox = draw.textbbox((0, 0), text, font=font)
        tw = bbox[2] - bbox[0]
        th = bbox[3] - bbox[1]
        tx = (w - tw) // 2
        ty = (h // 2 - th) // 2  # Upper half

        # Glow effect
        for offset in range(6, 0, -2):
            glow_alpha = int(40 * (1 - offset / 6))
            glow_color = (255, 200, 0, glow_alpha) if countdown_value > 0 \
                else (0, 255, 100, glow_alpha)
            # Draw glow by drawing text multiple times with offsets
            for dx, dy in [(-offset, 0), (offset, 0), (0, -offset), (0, offset)]:
                draw.text((tx + dx, ty + dy), text, font=font,
                          fill=glow_color[:3])

        # Shadow
        draw.text((tx + 4, ty + 4), text, font=font, fill=(0, 0, 0))

        # Main text
        color = (255, 220, 50) if countdown_value > 0 else (50, 255, 100)
        draw.text((tx, ty), text, font=font, fill=color)

        # Outline
        for dx, dy in [(-2, 0), (2, 0), (0, -2), (0, 2),
                        (-2, -2), (2, -2), (-2, 2), (2, 2)]:
            draw.text((tx + dx, ty + dy), text, font=font, fill=(0, 0, 0))
        draw.text((tx, ty), text, font=font, fill=color)

        return img

    def render_race_hud(
        self, img: Image.Image, characters: List[Character], frame: int
    ) -> Image.Image:
        """Render racing HUD with position indicators."""
        draw = ImageDraw.Draw(img)
        w, h = img.size

