    def render_winner_announcement(
        self, img: Image.Image, winner: Character,
        celebration_progress: float
    ) -> Image.Image:
        """Render winner announcement overlay."""
        draw = ImageDraw.Draw(img)
        w, h = img.size

        # Semi-transparent overlay
        overlay = Image.new("RGBA", img.size, (0, 0, 0, 0))
        overlay_draw = ImageDraw.Draw(overlay)

        # Fade in
        fade_alpha = int(MathUtils.ease_in_out(min(1.0, celebration_progress * 3)) * 160)
        overlay_draw.rectangle([0, 0, w, h], fill=(0, 0, 0, fade_alpha))
        img = Image.alpha_composite(img, overlay)
        draw = ImageDraw.Draw(img)

        if celebration_progress < 0.1:
            return img

        # "WINNER" text
        winner_font = self._get_font(100)
        text_progress = MathUtils.ease_out_bounce(
            min(1.0, (celebration_progress - 0.1) * 3)
        )

        winner_text = "🏆 WINNER 🏆"
        bbox = draw.textbbox((0, 0), winner_text, font=winner_font)
        tw = bbox[2] - bbox[0]
        th = bbox[3] - bbox[1]

        target_y = h // 6
        current_y = int(MathUtils.lerp(-100, target_y, text_progress))

        # Text glow
        glow_size = int(abs(math.sin(celebration_progress * 8)) * 4) + 2
        for offset in range(glow_size, 0, -1):
            alpha_frac = 1 - offset / glow_size
            glow_c = (255, 200, 0)
            for dx, dy in [(-offset, 0), (offset, 0), (0, -offset), (0, offset)]:
                draw.text(((w - tw) // 2 + dx, current_y + dy),
                          winner_text, font=winner_font, fill=glow_c)

        # Shadow
        draw.text(((w - tw) // 2 + 4, current_y + 4),
                  winner_text, font=winner_font, fill=(0, 0, 0))
        # Main
        draw.text(((w - tw) // 2, current_y),
                  winner_text, font=winner_font, fill=(255, 220, 50))

        # Winner name
        if celebration_progress > 0.3:
            name_progress = MathUtils.ease_elastic(
                min(1.0, (celebration_progress - 0.3) * 3)
            )
            name_font = self._get_font(70)
            name_text = winner.name
            bbox2 = draw.textbbox((0, 0), name_text, font=name_font)
            nw = bbox2[2] - bbox2[0]

            name_y = current_y + th + 30
            name_scale = name_progress

            body_color = winner.template.get("body_color", (255, 255, 255))
            # Shadow
            draw.text(((w - nw) // 2 + 3, int(name_y) + 3),
                      name_text, font=name_font, fill=(0, 0, 0))
            draw.text(((w - nw) // 2, int(name_y)),
                      name_text, font=name_font, fill=body_color)

        # Confetti during celebration
        if celebration_progress > 0.2:
            self._draw_celebration_confetti(draw, w, h, celebration_progress)

        return img

    def _draw_celebration_confetti(
        self, draw: ImageDraw.Draw, w: int, h: int, progress: float
    ):
        """Draw celebratory confetti particles."""
        rng = random.Random(42)  # Deterministic for consistent confetti
        num_confetti = int(progress * 80)
        for i in range(num_confetti):
            cx = rng.randint(0, w)
            cy = int((progress * 2 + rng.random()) * h * 0.4) % h
            size = rng.randint(4, 12)
            color = ColorUtils.random_vibrant()
            rot = rng.uniform(0, 360)
            # Simple rectangle confetti
            draw.rectangle([cx, cy, cx + size, cy + size // 2],
                           fill=color + (200,))

    def render_name_tags(
        self, img: Image.Image, characters: List[Character],
        scene: BaseScene
    ) -> Image.Image:
        """Render character name tags above their sprites."""
        draw = ImageDraw.Draw(img)
        font = self._get_font(18)

        for char in characters:
            if char.screen_x == 0 and char.screen_y == 0:
                continue

            name = char.name
            bbox = draw.textbbox((0, 0), name, font=font)
            tw = bbox[2] - bbox[0]

            tag_x = int(char.screen_x - tw // 2)
            tag_y = int(char.screen_y - self.config.animation.sprite_height // 2 - 28)

            body_color = char.template.get("body_color", (200, 200, 200))

            # Background pill
            pad = 6
            draw.rounded_rectangle(
                [tag_x - pad, tag_y - pad // 2,
                 tag_x + tw + pad, tag_y + 20 + pad // 2],
                radius=8,
                fill=(0, 0, 0, 160),
                outline=body_color + (200,),
                width=1,
            )
            draw.text((tag_x, tag_y), name, font=font, fill=(255, 255, 255))

        return img

