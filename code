class MathUtils:
    """Mathematical utility functions for animation and simulation."""

    @staticmethod
    def lerp(a: float, b: float, t: float) -> float:
        """Linear interpolation between a and b by factor t."""
        return a + (b - a) * max(0.0, min(1.0, t))

    @staticmethod
    def ease_in_out(t: float) -> float:
        """Smooth ease-in-out interpolation."""
        t = max(0.0, min(1.0, t))
        return t * t * (3.0 - 2.0 * t)

    @staticmethod
    def ease_in_cubic(t: float) -> float:
        """Cubic ease-in."""
        return t * t * t

    @staticmethod
    def ease_out_cubic(t: float) -> float:
        """Cubic ease-out."""
        return 1.0 - (1.0 - t) ** 3

    @staticmethod
    def ease_out_bounce(t: float) -> float:
        """Bounce ease-out for celebration effects."""
        if t < 1 / 2.75:
            return 7.5625 * t * t
        elif t < 2 / 2.75:
            t -= 1.5 / 2.75
            return 7.5625 * t * t + 0.75
        elif t < 2.5 / 2.75:
            t -= 2.25 / 2.75
            return 7.5625 * t * t + 0.9375
        else:
            t -= 2.625 / 2.75
            return 7.5625 * t * t + 0.984375

    @staticmethod
    def ease_elastic(t: float) -> float:
        """Elastic ease-out for bouncy effects."""
        if t == 0 or t == 1:
            return t
        p = 0.3
        s = p / 4
        return math.pow(2, -10 * t) * math.sin((t - s) * (2 * math.pi) / p) + 1

    @staticmethod
    def clamp(value: float, min_val: float, max_val: float) -> float:
        """Clamp a value between min and max."""
        return max(min_val, min(max_val, value))

    @staticmethod
    def map_range(
        value: float,
        in_min: float, in_max: float,
        out_min: float, out_max: float
    ) -> float:
        """Map a value from one range to another."""
        if in_max - in_min == 0:
            return out_min
        return (value - in_min) / (in_max - in_min) * (out_max - out_min) + out_min

    @staticmethod
    def oscillate(t: float, frequency: float = 1.0, amplitude: float = 1.0) -> float:
        """Generate oscillating value using sine wave."""
        return math.sin(t * frequency * 2 * math.pi) * amplitude

    @staticmethod
    def noise_1d(x: float, octaves: int = 3) -> float:
        """Simple 1D value noise approximation."""
        result = 0.0
        amp = 1.0
        freq = 1.0
        for _ in range(octaves):
            ix = int(math.floor(x * freq))
            frac = x * freq - ix
            frac = frac * frac * (3 - 2 * frac)
            a = (hash(ix) % 10000) / 10000.0
            b = (hash(ix + 1) % 10000) / 10000.0
            result += (a + (b - a) * frac) * amp
            amp *= 0.5
            freq *= 2.0
        return result

    @staticmethod
    def distance(x1: float, y1: float, x2: float, y2: float) -> float:
        """Euclidean distance between two points."""
        return math.sqrt((x2 - x1) ** 2 + (y2 - y1) ** 2)

    @staticmethod
    def angle_between(x1: float, y1: float, x2: float, y2: float) -> float:
        """Angle in degrees between two points."""
        return math.degrees(math.atan2(y2 - y1, x2 - x1))


class ColorUtils:
    """Color manipulation utilities."""

    @staticmethod
    def hex_to_rgb(hex_color: str) -> Tuple[int, int, int]:
        """Convert hex color string to RGB tuple."""
        hex_color = hex_color.lstrip('#')
        return tuple(int(hex_color[i:i+2], 16) for i in (0, 2, 4))

    @staticmethod
    def rgb_to_hex(r: int, g: int, b: int) -> str:
        """Convert RGB to hex string."""
        return f"#{r:02x}{g:02x}{b:02x}"

    @staticmethod
    def blend(
        c1: Tuple[int, int, int],
        c2: Tuple[int, int, int],
        t: float
    ) -> Tuple[int, int, int]:
        """Blend two colors by factor t."""
        return tuple(int(MathUtils.lerp(a, b, t)) for a, b in zip(c1, c2))

    @staticmethod
    def brighten(
        color: Tuple[int, int, int], factor: float
    ) -> Tuple[int, int, int]:
        """Brighten a color by a factor (1.0 = no change, >1 brighter)."""
        return tuple(
            min(255, int(c * factor)) for c in color
        )

    @staticmethod
    def darken(
        color: Tuple[int, int, int], factor: float
    ) -> Tuple[int, int, int]:
        """Darken a color by a factor (1.0 = no change, <1 darker)."""
        return tuple(
            max(0, int(c * factor)) for c in color
        )

    @staticmethod
    def random_vibrant() -> Tuple[int, int, int]:
        """Generate a random vibrant color."""
        h = random.random()
        s = random.uniform(0.7, 1.0)
        v = random.uniform(0.8, 1.0)
        r, g, b = colorsys.hsv_to_rgb(h, s, v)
        return (int(r * 255), int(g * 255), int(b * 255))

    @staticmethod
    def complementary(color: Tuple[int, int, int]) -> Tuple[int, int, int]:
        """Get complementary color."""
        r, g, b = [c / 255.0 for c in color]
        h, s, v = colorsys.rgb_to_hsv(r, g, b)
        h = (h + 0.5) % 1.0
        r2, g2, b2 = colorsys.hsv_to_rgb(h, s, v)
        return (int(r2 * 255), int(g2 * 255), int(b2 * 255))

    @staticmethod
    def gradient_color(
        t: float,
        colors: List[Tuple[int, int, int]]
    ) -> Tuple[int, int, int]:
        """Get color from a gradient defined by multiple color stops."""
        if len(colors) < 2:
            return colors[0] if colors else (0, 0, 0)
        t = MathUtils.clamp(t, 0.0, 1.0)
        segment = t * (len(colors) - 1)
        idx = int(segment)
        frac = segment - idx
        if idx >= len(colors) - 1:
            return colors[-1]
        return ColorUtils.blend(colors[idx], colors[idx + 1], frac)


class FileUtils:
