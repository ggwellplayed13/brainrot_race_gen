class SceneType(Enum):
    """Available scene/track types."""
    STANDARD_TRACK = auto()
    NEON_CITY = auto()
    SKY_TRACK = auto()
    JUNGLE = auto()
    SPACE = auto()
    OCEAN = auto()
    CANDY_RAINBOW = auto()
    LAVA_VOLCANO = auto()

class BaseScene(ABC):
    """Abstract base class for all scene types."""

    def __init__(self, config: MasterConfig, rng: random.Random):
        self.config = config
        self.sc = config.scene
        self.vc = config.video
        self.rng = rng
        self.parallax_offsets: List[float] = [0.0] * config.scene.parallax_layers
        self._cached_bg: Optional[Image.Image] = None

    @abstractmethod
    def render_background(self, frame: int, race_progress: float) -> Image.Image:
        """Render the full background for a frame."""
        pass

    @abstractmethod
    def get_lane_y(self, lane: int, total_lanes: int) -> int:
        """Get the Y coordinate for a given lane."""
        pass

    @abstractmethod
    def get_track_bounds(self) -> Tuple[int, int, int, int]:
        """Get track bounding box (x1, y1, x2, y2)."""
        pass

    def get_character_x(self, position: float) -> int:
        """Convert race position (0-1) to screen X coordinate."""
        track_x1 = int(self.vc.width * self.sc.ground_y_ratio * 0.15)
        track_x2 = int(self.vc.width * 0.92)
        return int(MathUtils.lerp(track_x1, track_x2, position))


class StandardTrackScene(BaseScene):
    """
    Standard racing track scene with sky, ground, lanes, and decorations.
    """

    def __init__(self, config: MasterConfig, rng: random.Random):
        super().__init__(config, rng)
        self.crowd_sprites: List[Dict] = []
        self.cloud_positions: List[Dict] = []
        self.decoration_elements: List[Dict] = []

        # Generate random scene elements
        self._generate_clouds()
        self._generate_crowd()
        self._generate_decorations()

        # Color scheme
        self.sky_colors = [
            ((20, 10, 50), (60, 30, 100)),    # Night purple
            ((135, 180, 255), (200, 220, 255)), # Day blue
            ((255, 130, 50), (255, 200, 100)),  # Sunset
            ((30, 30, 50), (80, 40, 80)),       # Dusk
            ((50, 180, 220), (150, 220, 255)),  # Cyan sky
        ]
        chosen = rng.choice(self.sky_colors)
        self.sky_top = chosen[0]
        self.sky_bottom = chosen[1]

        # Track colors
        track_colors = [
            (90, 90, 100),   # Gray
            (120, 80, 60),   # Brown/dirt
            (70, 100, 70),   # Green/grass
            (80, 80, 120),   # Blue-gray
        ]
        self.track_color = rng.choice(track_colors)

        # Generate static background
        self._generate_static_bg()

    def _generate_clouds(self):
        """Generate random cloud positions."""
        for _ in range(self.rng.randint(3, 8)):
            self.cloud_positions.append({
                "x": self.rng.randint(-100, self.vc.width + 100),
                "y": self.rng.randint(30, 300),
                "width": self.rng.randint(80, 200),
                "height": self.rng.randint(30, 60),
                "speed": self.rng.uniform(0.3, 1.2),
                "opacity": self.rng.randint(100, 200),
            })

    def _generate_crowd(self):
        """Generate crowd silhouettes."""
        if not self.sc.crowd_enabled:
            return
        for _ in range(self.rng.randint(20, 50)):
            self.crowd_sprites.append({
                "x": self.rng.randint(0, self.vc.width),
                "y_offset": self.rng.randint(-10, 10),
                "height": self.rng.randint(15, 30),
                "width": self.rng.randint(8, 16),
                "color": (
                    self.rng.randint(30, 80),
                    self.rng.randint(30, 80),
                    self.rng.randint(30, 80),
                ),
                "cheer_phase": self.rng.uniform(0, 2 * math.pi),
                "cheer_speed": self.rng.uniform(2, 6),
            })

    def _generate_decorations(self):
        """Generate track decorations (flags, cones, etc.)."""
        # Finish line poles
        self.decoration_elements.append({
            "type": "finish_banner",
            "x": self.sc.finish_line_x,
        })
        # Lane markers
        for i in range(6):
            self.decoration_elements.append({
                "type": "cone",
                "x": self.rng.uniform(0.1, 0.9),
                "lane_edge": i,
            })

    def _generate_static_bg(self):
        """Pre-generate the static background image."""
        w, h = self.vc.width, self.vc.height
        img = Image.new("RGBA", (w, h), (0, 0, 0, 255))
        draw = ImageDraw.Draw(img)

        # Sky gradient
        ground_y = int(h * self.sc.ground_y_ratio)
        for y in range(ground_y):
            t = y / max(1, ground_y)
            color = ColorUtils.blend(self.sky_top, self.sky_bottom, t)
            draw.line([(0, y), (w, y)], fill=color + (255,))

        # Stars if dark sky
        avg_brightness = sum(self.sky_top) / 3
        if avg_brightness < 80:
            for _ in range(100):
                sx = self.rng.randint(0, w)
                sy = self.rng.randint(0, ground_y - 50)
                brightness = self.rng.randint(150, 255)
                size = self.rng.choice([1, 1, 1, 2])
                draw.ellipse([sx, sy, sx + size, sy + size],
                             fill=(brightness, brightness, brightness, self.rng.randint(100, 255)))

        # Ground / track area
        track_top = ground_y
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio))

        # Track background with gradient
        for y in range(track_top, track_bottom):
            t = (y - track_top) / max(1, track_bottom - track_top)
            base = self.track_color
            shade = ColorUtils.darken(base, 1.0 - t * 0.3)
            draw.line([(0, y), (w, y)], fill=shade + (255,))

        # Lane lines
        num_lanes = self.config.race.lane_count
        for i in range(num_lanes + 1):
            lane_y = int(MathUtils.lerp(track_top + 20, track_bottom - 20,
                                        i / num_lanes))
            # Dashed line
            dash_len = 20
            gap_len = 15
            x = 0
            while x < w:
                draw.line([(x, lane_y), (x + dash_len, lane_y)],
                          fill=self.sc.lane_line_color + (120,),
                          width=self.sc.lane_line_width)
                x += dash_len + gap_len

        # Bottom area (below track) - audience area
        for y in range(track_bottom, h):
            t = (y - track_bottom) / max(1, h - track_bottom)
            color = ColorUtils.blend((50, 40, 60), (30, 25, 40), t)
            draw.line([(0, y), (w, y)], fill=color + (255,))

        # Finish line
        finish_x = int(w * self.sc.finish_line_x)
        checker_size = 12
        for y in range(track_top, track_bottom):
            for cx in range(finish_x - checker_size, finish_x + checker_size, checker_size):
                row = (y - track_top) // checker_size
                col = (cx - (finish_x - checker_size)) // checker_size
                color = (255, 255, 255) if (row + col) % 2 == 0 else (0, 0, 0)
                draw.rectangle(
                    [cx, y, cx + checker_size, min(y + checker_size, track_bottom)],
                    fill=color + (200,)
                )

        self._cached_bg = img

    def render_background(self, frame: int, race_progress: float) -> Image.Image:
        """Render background with animated elements."""
        # Start with cached static background
        img = self._cached_bg.copy()
        draw = ImageDraw.Draw(img)
        w, h = self.vc.width, self.vc.height
        ground_y = int(h * self.sc.ground_y_ratio)

        # Animate clouds
        for cloud in self.cloud_positions:
            cx = (cloud["x"] + frame * cloud["speed"]) % (w + 200) - 100
            cy = cloud["y"]
            cw = cloud["width"]
            ch = cloud["height"]
            opacity = cloud["opacity"]

            # Cloud shape (overlapping ellipses)
            cloud_color = (255, 255, 255, opacity)
            draw.ellipse([int(cx - cw//2), cy - ch//2,
                          int(cx + cw//2), cy + ch//2], fill=cloud_color)
            draw.ellipse([int(cx - cw//3), cy - ch//2 - ch//4,
                          int(cx + cw//3), cy + ch//4], fill=cloud_color)

        # Animate crowd
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio))
        for person in self.crowd_sprites:
            px = person["x"]
            cheer = math.sin(frame * 0.1 * person["cheer_speed"] + person["cheer_phase"])
            py = track_bottom + 10 + person["y_offset"] + int(abs(cheer) * 5)
            pw = person["width"]
            ph = person["height"]
            # Body
            draw.ellipse([px - pw//2, py - ph, px + pw//2, py],
                         fill=person["color"] + (200,))
            # Head
            head_r = pw // 2
            draw.ellipse([px - head_r, py - ph - head_r*2,
                          px + head_r, py - ph],
                         fill=ColorUtils.brighten(person["color"], 1.3) + (200,))
            # Arms (cheering)
            if cheer > 0.5:
                draw.line([px, py - ph + 5, px - pw, py - ph - 10],
                          fill=person["color"] + (200,), width=2)
                draw.line([px, py - ph + 5, px + pw, py - ph - 10],
                          fill=person["color"] + (200,), width=2)

        return img

    def get_lane_y(self, lane: int, total_lanes: int) -> int:
        """Get Y coordinate for a lane."""
        h = self.vc.height
        track_top = int(h * self.sc.ground_y_ratio) + 30
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio)) - 30
        t = (lane + 0.5) / total_lanes
        return int(MathUtils.lerp(track_top, track_bottom, t))

    def get_track_bounds(self) -> Tuple[int, int, int, int]:
        """Get track bounds."""
        h = self.vc.height
        w = self.vc.width
        return (
            0,
            int(h * self.sc.ground_y_ratio),
            w,
            int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio)),
        )


class NeonCityScene(BaseScene):
    """Futuristic neon city track scene."""

    def __init__(self, config: MasterConfig, rng: random.Random):
        super().__init__(config, rng)
        self.buildings: List[Dict] = []
        self.neon_colors = [
            (255, 0, 100), (0, 255, 200), (255, 100, 0),
            (100, 0, 255), (0, 200, 255), (255, 255, 0),
        ]
        self._generate_buildings()
        self._generate_static_bg()

    def _generate_buildings(self):
        """Generate random building silhouettes."""
        x = 0
        while x < self.vc.width:
            bw = self.rng.randint(40, 120)
            bh = self.rng.randint(100, 500)
            self.buildings.append({
                "x": x,
                "width": bw,
                "height": bh,
                "neon_color": self.rng.choice(self.neon_colors),
                "windows": self.rng.randint(2, 6),
                "glow_phase": self.rng.uniform(0, 2 * math.pi),
            })
            x += bw + self.rng.randint(5, 20)

    def _generate_static_bg(self):
        """Generate neon city background."""
        w, h = self.vc.width, self.vc.height
        img = Image.new("RGBA", (w, h), (10, 5, 20, 255))
        draw = ImageDraw.Draw(img)

        ground_y = int(h * self.sc.ground_y_ratio)

        # Dark sky gradient
        for y in range(ground_y):
            t = y / max(1, ground_y)
            color = ColorUtils.blend((5, 0, 15), (20, 10, 40), t)
            draw.line([(0, y), (w, y)], fill=color + (255,))

        # Buildings
        for bld in self.buildings:
            bx = bld["x"]
            bw = bld["width"]
            bh = bld["height"]
            by = ground_y - bh
            # Building body
            draw.rectangle([bx, by, bx + bw, ground_y],
                           fill=(15, 10, 25, 255),
                           outline=bld["neon_color"] + (60,), width=1)
            # Windows
            wrows = bh // 30
            wcols = bw // 20
            for wr in range(wrows):
                for wc in range(wcols):
                    wx = bx + 5 + wc * 20
                    wy = by + 10 + wr * 30
                    if self.rng.random() > 0.3:
                        glow = self.rng.choice(self.neon_colors)
                        draw.rectangle([wx, wy, wx + 10, wy + 15],
                                       fill=ColorUtils.darken(glow, 0.3) + (150,))

        # Track area
        track_top = ground_y
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio))
        for y in range(track_top, min(track_bottom, h)):
            t = (y - track_top) / max(1, track_bottom - track_top)
            color = ColorUtils.blend((20, 15, 35), (10, 5, 20), t)
            draw.line([(0, y), (w, y)], fill=color + (255,))

        # Neon lane lines
        num_lanes = self.config.race.lane_count
        for i in range(num_lanes + 1):
            lane_y = int(MathUtils.lerp(track_top + 20, track_bottom - 20,
                                        i / num_lanes))
            neon = self.rng.choice(self.neon_colors)
            draw.line([(0, lane_y), (w, lane_y)],
                      fill=neon + (100,), width=2)

        # Below track
        for y in range(track_bottom, h):
            draw.line([(0, y), (w, y)], fill=(8, 4, 16, 255))

        # Finish line (neon)
        finish_x = int(w * self.sc.finish_line_x)
        for y in range(track_top, track_bottom, 4):
            color = self.rng.choice(self.neon_colors)
            draw.rectangle([finish_x - 6, y, finish_x + 6, y + 2],
                           fill=color + (200,))

        self._cached_bg = img

    def render_background(self, frame: int, race_progress: float) -> Image.Image:
        """Render neon city with animated glow effects."""
        img = self._cached_bg.copy()
        draw = ImageDraw.Draw(img)

        # Animated neon glow on buildings
        for bld in self.buildings:
            glow_intensity = (math.sin(frame * 0.05 + bld["glow_phase"]) + 1) / 2
            if glow_intensity > 0.7:
                bx = bld["x"]
                bw = bld["width"]
                ground_y = int(self.vc.height * self.sc.ground_y_ratio)
                by = ground_y - bld["height"]
                nc = bld["neon_color"]
                alpha = int(glow_intensity * 40)
                draw.rectangle([bx - 2, by - 2, bx + bw + 2, ground_y],
                               outline=nc + (alpha,), width=2)

        return img

    def get_lane_y(self, lane: int, total_lanes: int) -> int:
        h = self.vc.height
        track_top = int(h * self.sc.ground_y_ratio) + 30
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio)) - 30
        t = (lane + 0.5) / total_lanes
        return int(MathUtils.lerp(track_top, track_bottom, t))

    def get_track_bounds(self) -> Tuple[int, int, int, int]:
        h = self.vc.height
        w = self.vc.width
        return (0, int(h * self.sc.ground_y_ratio), w,
                int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio)))


class CandyRainbowScene(BaseScene):
    """Candy/Rainbow themed race track - vibrant and super colorful for kids."""

    def __init__(self, config: MasterConfig, rng: random.Random):
        super().__init__(config, rng)
        self.candy_colors = [
            (255, 80, 150),   # Hot pink
            (255, 200, 50),   # Yellow
            (100, 220, 100),  # Green
            (100, 180, 255),  # Sky blue
            (200, 100, 255),  # Purple
            (255, 140, 60),   # Orange
        ]
        self.floating_elements: List[Dict] = []
        self.cloud_positions: List[Dict] = []
        self._generate_elements()
        self._generate_clouds()
        self._generate_static_bg()

    def _generate_elements(self):
        """Generate floating candy/star elements."""
        for _ in range(30):
            self.floating_elements.append({
                "x": self.rng.randint(0, self.vc.width),
                "y": self.rng.randint(20, int(self.vc.height * self.sc.ground_y_ratio) - 20),
                "type": self.rng.choice(["star", "circle", "diamond"]),
                "color": self.rng.choice(self.candy_colors),
                "size": self.rng.randint(8, 24),
                "speed": self.rng.uniform(0.2, 1.5),
                "phase": self.rng.uniform(0, 2 * math.pi),
                "spin_speed": self.rng.uniform(0.02, 0.08),
            })

    def _generate_clouds(self):
        """Generate fluffy candy clouds."""
        for _ in range(6):
            self.cloud_positions.append({
                "x": self.rng.randint(-100, self.vc.width + 100),
                "y": self.rng.randint(30, 200),
                "width": self.rng.randint(100, 250),
                "height": self.rng.randint(40, 80),
                "speed": self.rng.uniform(0.2, 0.8),
                "color": self.rng.choice([(255, 200, 220), (220, 200, 255), (200, 240, 255)]),
                "opacity": self.rng.randint(160, 230),
            })

    def _generate_static_bg(self):
        """Generate candy/rainbow background."""
        w, h = self.vc.width, self.vc.height
        img = Image.new("RGBA", (w, h), (0, 0, 0, 255))
        draw = ImageDraw.Draw(img)

        ground_y = int(h * self.sc.ground_y_ratio)

        # Rainbow sky gradient
        rainbow_sky = [
            (255, 120, 180),  # Pink
            (255, 180, 80),   # Orange
            (255, 240, 80),   # Yellow
            (120, 220, 120),  # Green
            (80, 180, 255),   # Blue
        ]
        for y in range(ground_y):
            t = y / max(1, ground_y)
            seg = t * (len(rainbow_sky) - 1)
            idx = int(seg)
            frac = seg - idx
            if idx >= len(rainbow_sky) - 1:
                color = rainbow_sky[-1]
            else:
                c1, c2 = rainbow_sky[idx], rainbow_sky[idx + 1]
                color = ColorUtils.blend(c1, c2, frac)
            draw.line([(0, y), (w, y)], fill=color + (255,))

        # Track area with rainbow lanes
        track_top = ground_y
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio))
        num_lanes = self.config.race.lane_count
        lane_colors = [
            (255, 150, 200),  # Pink
            (255, 220, 100),  # Yellow
            (150, 255, 150),  # Green
            (150, 200, 255),  # Blue
            (220, 150, 255),  # Purple
        ]

        for i in range(num_lanes):
            lane_top = int(MathUtils.lerp(track_top, track_bottom, i / num_lanes))
            lane_bot = int(MathUtils.lerp(track_top, track_bottom, (i + 1) / num_lanes))
            lc = lane_colors[i % len(lane_colors)]
            for y in range(lane_top, lane_bot):
                t = (y - lane_top) / max(1, lane_bot - lane_top)
                shade = ColorUtils.blend(lc, ColorUtils.darken(lc, 0.7), t * 0.4)
                draw.line([(0, y), (w, y)], fill=shade + (255,))

        # Lane dividers (white dashed)
        for i in range(1, num_lanes):
            ly = int(MathUtils.lerp(track_top, track_bottom, i / num_lanes))
            x = 0
            while x < w:
                draw.line([(x, ly), (x + 20, ly)], fill=(255, 255, 255, 180), width=3)
                x += 35

        # Below track
        for y in range(track_bottom, h):
            t = (y - track_bottom) / max(1, h - track_bottom)
            color = ColorUtils.blend((200, 100, 200), (150, 50, 150), t)
            draw.line([(0, y), (w, y)], fill=color + (255,))

        # Finish line (checkerboard)
        finish_x = int(w * self.sc.finish_line_x)
        checker_size = 14
        finish_colors = [(255, 255, 255), (255, 50, 150)]
        for y in range(track_top, track_bottom):
            for cx_pos in range(finish_x - checker_size, finish_x + checker_size, checker_size):
                row = (y - track_top) // checker_size
                col = (cx_pos - (finish_x - checker_size)) // checker_size
                color = finish_colors[(row + col) % 2]
                draw.rectangle([cx_pos, y, cx_pos + checker_size,
                                min(y + checker_size, track_bottom)],
                               fill=color + (220,))

        self._cached_bg = img

    def render_background(self, frame: int, race_progress: float) -> Image.Image:
        """Render candy/rainbow background with animated elements."""
        img = self._cached_bg.copy()
        draw = ImageDraw.Draw(img)
        w, h = self.vc.width, self.vc.height
        ground_y = int(h * self.sc.ground_y_ratio)
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio))

        # Pulsing background tint
        pulse = (math.sin(frame * 0.05) + 1) / 2 * 15
        if pulse > 5:
            overlay = Image.new("RGBA", img.size, (255, 200, 255, int(pulse)))
            img = Image.alpha_composite(img, overlay)
            draw = ImageDraw.Draw(img)

        # Animated floating elements
        for elem in self.floating_elements:
            ex = int((elem["x"] + frame * elem["speed"]) % (w + 50) - 25)
            ey = int(elem["y"] + math.sin(frame * 0.03 + elem["phase"]) * 10)
            es = elem["size"]
            ec = elem["color"]
            spin = frame * elem["spin_speed"]
            if elem["type"] == "star":
                points = []
                for j in range(5):
                    outer_a = spin + j * 2 * math.pi / 5 - math.pi / 2
                    inner_a = outer_a + math.pi / 5
                    points.append((ex + int(math.cos(outer_a) * es), ey + int(math.sin(outer_a) * es)))
                    points.append((ex + int(math.cos(inner_a) * es // 2), ey + int(math.sin(inner_a) * es // 2)))
                if len(points) >= 3:
                    draw.polygon(points, fill=ec + (200,))
            elif elem["type"] == "circle":
                draw.ellipse([ex - es, ey - es, ex + es, ey + es], fill=ec + (180,))
            elif elem["type"] == "diamond":
                pts = [(ex, ey - es), (ex + es, ey), (ex, ey + es), (ex - es, ey)]
                draw.polygon(pts, fill=ec + (180,))

        # Animate candy clouds
        for cloud in self.cloud_positions:
            cx = int((cloud["x"] + frame * cloud["speed"]) % (w + 300) - 150)
            cy = cloud["y"]
            cw = cloud["width"]
            ch = cloud["height"]
            cc = cloud["color"]
            op = cloud["opacity"]
            draw.ellipse([cx - cw//2, cy - ch//2, cx + cw//2, cy + ch//2], fill=cc + (op,))
            draw.ellipse([cx - cw//3, cy - ch//2 - ch//4, cx + cw//3, cy + ch//4], fill=cc + (op,))
            draw.ellipse([cx, cy - ch//2 - ch//6, cx + cw//3, cy + ch//4], fill=cc + (op,))

        # Animated finish line flash
        if race_progress > 0.5:
            finish_x = int(w * self.sc.finish_line_x)
            flash_colors = [
                (255, 80, 150), (255, 200, 50), (100, 255, 100),
                (100, 180, 255), (200, 100, 255),
            ]
            flash_idx = (frame // 3) % len(flash_colors)
            fc = flash_colors[flash_idx]
            alpha = int(100 + 100 * abs(math.sin(frame * 0.2)))
            draw.rectangle([finish_x - 8, int(h * self.sc.ground_y_ratio),
                           finish_x + 8, track_bottom],
                          fill=fc + (alpha,))

        # Ground decorations - flowers
        flower_colors = [(255, 80, 150), (255, 220, 50), (100, 255, 100)]
        rng_dec = random.Random(42)
        for i in range(20):
            fx = rng_dec.randint(0, w)
            fy = track_bottom + rng_dec.randint(5, 25)
            fc = flower_colors[i % len(flower_colors)]
            draw.ellipse([fx-5, fy-5, fx+5, fy+5], fill=fc + (200,))
            draw.ellipse([fx-2, fy-2, fx+2, fy+2], fill=(255, 255, 100, 220))

        return img

    def get_lane_y(self, lane: int, total_lanes: int) -> int:
        h = self.vc.height
        track_top = int(h * self.sc.ground_y_ratio) + 30
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio)) - 30
        t = (lane + 0.5) / total_lanes
        return int(MathUtils.lerp(track_top, track_bottom, t))

    def get_track_bounds(self) -> Tuple[int, int, int, int]:
        h = self.vc.height
        w = self.vc.width
        return (0, int(h * self.sc.ground_y_ratio), w,
                int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio)))


class LavaVolcanoScene(BaseScene):
    """Lava/Volcano themed race track - dramatic and intense."""

    def __init__(self, config: MasterConfig, rng: random.Random):
        super().__init__(config, rng)
        self.volcanoes: List[Dict] = []
        self.lava_particles: List[Dict] = []
        self._generate_volcanoes()
        self._generate_lava_particles()
        self._generate_static_bg()

    def _generate_volcanoes(self):
        """Generate volcano silhouettes."""
        x = 0
        while x < self.vc.width:
            vw = self.rng.randint(80, 200)
            vh = self.rng.randint(150, 400)
            self.volcanoes.append({
                "x": x,
                "width": vw,
                "height": vh,
                "eruption_phase": self.rng.uniform(0, 2 * math.pi),
                "eruption_speed": self.rng.uniform(0.03, 0.08),
            })
            x += vw + self.rng.randint(20, 80)

    def _generate_lava_particles(self):
        """Generate animated lava particles."""
        for _ in range(40):
            self.lava_particles.append({
                "x": self.rng.randint(0, self.vc.width),
                "y": self.rng.randint(int(self.vc.height * 0.3), int(self.vc.height * 0.5)),
                "vy": self.rng.uniform(-2, -6),
                "vx": self.rng.uniform(-1, 1),
                "size": self.rng.randint(4, 14),
                "color": self.rng.choice([(255, 80, 0), (255, 160, 0), (255, 200, 50)]),
                "phase": self.rng.uniform(0, 2 * math.pi),
                "lifetime": self.rng.randint(20, 60),
            })

    def _generate_static_bg(self):
        """Generate lava/volcano background."""
        w, h = self.vc.width, self.vc.height
        img = Image.new("RGBA", (w, h), (0, 0, 0, 255))
        draw = ImageDraw.Draw(img)

        ground_y = int(h * self.sc.ground_y_ratio)

        # Dark reddish sky
        for y in range(ground_y):
            t = y / max(1, ground_y)
            color = ColorUtils.blend((80, 10, 10), (200, 60, 20), t)
            draw.line([(0, y), (w, y)], fill=color + (255,))

        # Volcano silhouettes
        for vol in self.volcanoes:
            vx = vol["x"]
            vw = vol["width"]
            vh = vol["height"]
            base_y = ground_y
            peak_y = ground_y - vh
            peak_x = vx + vw // 2
            points = [
                (vx, base_y),
                (peak_x, peak_y),
                (vx + vw, base_y),
            ]
            draw.polygon(points, fill=(60, 20, 10, 255))
            draw.ellipse([peak_x - vw//8, peak_y - 10,
                         peak_x + vw//8, peak_y + 10],
                        fill=(120, 30, 10, 255))

        # Track area - dark obsidian/lava
        track_top = ground_y
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio))

        for y in range(track_top, track_bottom):
            t = (y - track_top) / max(1, track_bottom - track_top)
            color = ColorUtils.blend((40, 15, 10), (25, 8, 5), t)
            draw.line([(0, y), (w, y)], fill=color + (255,))

        # Lava lane lines (glowing orange-red)
        num_lanes = self.config.race.lane_count
        lava_line_colors = [
            (255, 100, 0), (255, 60, 0), (255, 140, 0),
            (255, 80, 0), (255, 120, 0),
        ]
        for i in range(num_lanes + 1):
            ly = int(MathUtils.lerp(track_top + 15, track_bottom - 15, i / num_lanes))
            lc = lava_line_colors[i % len(lava_line_colors)]
            draw.line([(0, ly), (w, ly)], fill=lc + (160,), width=3)

        # Lava cracks in track
        rng_crack = random.Random(99)
        for _ in range(15):
            cx_start = rng_crack.randint(0, w)
            cy_start = rng_crack.randint(track_top, track_bottom)
            crack_color = rng_crack.choice([(255, 100, 0, 180), (255, 160, 0, 150)])
            points = [(cx_start, cy_start)]
            for _ in range(5):
                cx_start += rng_crack.randint(-20, 20)
                cy_start += rng_crack.randint(-5, 5)
                points.append((cx_start, cy_start))
            if len(points) >= 2:
                for j in range(len(points) - 1):
                    draw.line([points[j], points[j+1]], fill=crack_color, width=2)

        # Below track
        for y in range(track_bottom, h):
            draw.line([(0, y), (w, y)], fill=(20, 5, 5, 255))

        # Finish line
        finish_x = int(w * self.sc.finish_line_x)
        checker_size = 12
        for y in range(track_top, track_bottom):
            for cx_pos in range(finish_x - checker_size, finish_x + checker_size, checker_size):
                row = (y - track_top) // checker_size
                col = (cx_pos - (finish_x - checker_size)) // checker_size
                color = (255, 255, 255) if (row + col) % 2 == 0 else (255, 80, 0)
                draw.rectangle([cx_pos, y, cx_pos + checker_size,
                                min(y + checker_size, track_bottom)],
                               fill=color + (220,))

        self._cached_bg = img

    def render_background(self, frame: int, race_progress: float) -> Image.Image:
        """Render lava scene with animated eruptions."""
        img = self._cached_bg.copy()
        draw = ImageDraw.Draw(img)
        w, h = self.vc.width, self.vc.height
        ground_y = int(h * self.sc.ground_y_ratio)
        track_top = ground_y
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio))

        # Animated lava glow overlay
        glow_intensity = (math.sin(frame * 0.05) + 1) / 2 * 20
        if glow_intensity > 5:
            overlay = Image.new("RGBA", img.size, (255, 60, 0, int(glow_intensity)))
            img = Image.alpha_composite(img, overlay)
            draw = ImageDraw.Draw(img)

        # Volcano eruptions
        for vol in self.volcanoes:
            phase = vol["eruption_phase"] + frame * vol["eruption_speed"]
            erupt_intensity = (math.sin(phase) + 1) / 2
            if erupt_intensity > 0.6:
                peak_x = vol["x"] + vol["width"] // 2
                peak_y = ground_y - vol["height"]
                num_sparks = int(erupt_intensity * 8) + 2
                for spark_i in range(num_sparks):
                    spark_rng = random.Random(frame + vol["x"] + spark_i)
                    sx = peak_x + spark_rng.randint(-15, 15)
                    sy = peak_y - spark_rng.randint(0, int(40 * erupt_intensity))
                    sr = spark_rng.randint(2, 6)
                    sc_color = spark_rng.choice([(255, 100, 0), (255, 200, 50), (255, 60, 0)])
                    draw.ellipse([sx - sr, sy - sr, sx + sr, sy + sr], fill=sc_color + (200,))

        # Lava crack glow
        lava_glow = (math.sin(frame * 0.08) + 1) / 2
        if lava_glow > 0.5:
            glow_overlay = Image.new("RGBA", img.size, (0, 0, 0, 0))
            glow_draw = ImageDraw.Draw(glow_overlay)
            rng_glow = random.Random(frame // 5)
            for _ in range(5):
                gx = rng_glow.randint(0, w)
                gy = rng_glow.randint(track_top, track_bottom)
                gr = rng_glow.randint(5, 20)
                ga = int(lava_glow * 80)
                glow_draw.ellipse([gx - gr, gy - gr, gx + gr, gy + gr],
                                 fill=(255, 120, 0, ga))
            img = Image.alpha_composite(img, glow_overlay)
            draw = ImageDraw.Draw(img)

        # Animated finish line
        if race_progress > 0.4:
            finish_x = int(w * self.sc.finish_line_x)
            flash_colors = [(255, 100, 0), (255, 200, 50), (255, 255, 255)]
            flash_idx = (frame // 4) % len(flash_colors)
            fc = flash_colors[flash_idx]
            alpha = int(80 + 120 * abs(math.sin(frame * 0.2)))
            draw.rectangle([finish_x - 10, track_top, finish_x + 10, track_bottom],
                          fill=fc + (alpha,))

        return img

    def get_lane_y(self, lane: int, total_lanes: int) -> int:
        h = self.vc.height
        track_top = int(h * self.sc.ground_y_ratio) + 30
        track_bottom = int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio)) - 30
        t = (lane + 0.5) / total_lanes
        return int(MathUtils.lerp(track_top, track_bottom, t))

    def get_track_bounds(self) -> Tuple[int, int, int, int]:
        h = self.vc.height
        w = self.vc.width
        return (0, int(h * self.sc.ground_y_ratio), w,
                int(h * (self.sc.ground_y_ratio + self.sc.track_height_ratio)))


class SceneFactory:
    """Factory for creating scenes."""

    SCENE_MAP = {
        SceneType.STANDARD_TRACK: StandardTrackScene,
        SceneType.NEON_CITY: NeonCityScene,
        SceneType.CANDY_RAINBOW: CandyRainbowScene,
        SceneType.LAVA_VOLCANO: LavaVolcanoScene,
    }

    @classmethod
    def create_scene(
        cls, scene_type: SceneType, config: MasterConfig, rng: random.Random
    ) -> BaseScene:
        scene_cls = cls.SCENE_MAP.get(scene_type, StandardTrackScene)
        return scene_cls(config, rng)

    @classmethod
    def random_scene(cls, config: MasterConfig, rng: random.Random) -> BaseScene:
        scene_type = rng.choice(list(cls.SCENE_MAP.keys()))
        log.info(f"  Selected scene: {scene_type.name}")
        return cls.create_scene(scene_type, config, rng)

