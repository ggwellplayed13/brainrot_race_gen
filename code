class RaceOrchestrator:
    """
    Master orchestrator that coordinates all systems to generate a complete race video.
    This is the main entry point for generating races.
    """

    def __init__(self, config: Optional[MasterConfig] = None):
        self.config = config or MasterConfig()
        FileUtils.ensure_dir(self.config.output_dir)

        # Initialize seed
        if self.config.seed is None:
            self.config.randomize_seed()
        self.rng = random.Random(self.config.seed)

        log.section("RACE ORCHESTRATOR INITIALIZED")
        log.info(f"  Seed: {self.config.seed}")
        log.info(f"  Output: {self.config.output_dir}")

    def generate_race(self, race_index: int = 0) -> str:
        """
        Generate a single complete race video.

        Returns:
            Path to the generated video file.
        """
        # Per-race seed for reproducibility
        race_seed = self.rng.randint(0, 2**32 - 1)
        race_rng = random.Random(race_seed)
        log.section(f"GENERATING RACE #{race_index + 1} (seed={race_seed})")

        # 1. Create characters
        log.info("📦 Creating characters...")
        char_factory = CharacterFactory(self.config)
        characters = char_factory.create_characters(
            self.config.race.num_characters, race_rng
        )

        # 2. Create scene
        log.info("🎨 Creating scene...")
        scene = SceneFactory.random_scene(self.config, race_rng)

        # 3. Create race simulator
        log.info("🏎️ Initializing race simulation...")
        simulator = RaceSimulator(self.config, race_rng)
        simulator.initialize(characters)

        # 4. Create event engine
        log.info("⚡ Initializing event engine...")
        event_engine = RandomEventEngine(self.config, race_rng)

        # 5. Create frame renderer
        log.info("🖼️ Initializing frame renderer...")
        frame_renderer = FrameRenderer(self.config)

        # 6. Pre-simulate to determine all states
        log.info("🔄 Pre-simulating race...")
        all_states: List[RaceState] = []
        all_events: List[List[GameEvent]] = []

        sim_state = simulator.state
        total_frames = sim_state.total_frames

        for frame_idx in range(total_frames):
            state = simulator.simulate_frame()
            events = event_engine.update(state)
            all_states.append(deepcopy(state))
            all_events.append(list(events))

            if simulator.is_finished():
                # Pad remaining frames
                for _ in range(frame_idx + 1, total_frames):
                    all_states.append(deepcopy(state))
                    all_events.append([])
                break

        actual_frames = len(all_states)
        duration = actual_frames / self.config.video.fps
        log.info(f"  Simulation complete: {actual_frames} frames, {duration:.1f}s")

        # 7. Generate audio
        log.info("🔊 Generating audio...")
        audio_manager = AudioManager(self.config)
        winner_name = simulator.state.winner.name if simulator.state.winner else "Unknown"
        audio_path = audio_manager.generate_race_audio(
            duration, winner_name,
            self.config.race.countdown_duration,
            duration - self.config.race.countdown_duration - self.config.race.winner_celebration_duration,
        )

        # 8. Create frame generator for video encoding
        log.info("🎬 Preparing video encoding...")

        # Frame cache for the frame generator
        frame_cache: Dict[int, np.ndarray] = {}

        def make_frame(t: float) -> np.ndarray:
            """Generate frame for time t."""
            frame_idx = int(t * self.config.video.fps)
            frame_idx = min(frame_idx, actual_frames - 1)

            if frame_idx in frame_cache:
                return frame_cache[frame_idx]

            state = all_states[frame_idx]
            events = all_events[frame_idx]

            rendered = frame_renderer.render_frame(
                scene, state, events, frame_idx
            )

            # Cache last N frames to save memory
            frame_cache[frame_idx] = rendered
            if len(frame_cache) > 30:
                oldest = min(frame_cache.keys())
                del frame_cache[oldest]

            return rendered

        # 9. Encode video
        output_filename = FileUtils.unique_filename(
            prefix=f"race_{race_index:03d}", ext=".mp4"
        )
        output_path = os.path.join(self.config.output_dir, output_filename)

        encoder = VideoEncoder(self.config)
        result_path = encoder.encode_video(
            frame_generator=make_frame,
            duration=duration,
            audio_path=audio_path,
            output_path=output_path,
        )

        # 10. Cleanup
        audio_manager.cleanup()
        frame_cache.clear()

        log.info(f"  🏁 Race #{race_index + 1} complete!")
        log.info(f"     Winner: {winner_name}")
        log.info(f"     File: {result_path}")

        return result_path

    def generate_batch(self, count: Optional[int] = None) -> List[str]:
        """
        Generate multiple race videos in batch.

        Args:
            count: Number of races to generate (uses config.batch_size if None).

        Returns:
            List of paths to generated video files.
        """
        num_races = count or self.config.batch_size
        log.section(f"BATCH GENERATION: {num_races} RACES")

        results = []
        for i in range(num_races):
            try:
                path = self.generate_race(i)
                results.append(path)
            except Exception as e:
                log.error(f"  ❌ Race #{i + 1} failed: {e}")
                traceback.print_exc()
                continue

        log.section("BATCH COMPLETE")
        log.info(f"  Generated {len(results)}/{num_races} videos successfully.")
        for path in results:
            log.info(f"    📹 {path}")

        return results

