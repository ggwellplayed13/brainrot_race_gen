    def render_who_will_win(
        self, img: Image.Image, frame: int, who_will_win_frame: int
    ) -> Image.Image:
        """Render dramatic WHO WILL WIN?! 🤔 text with scale-in bounce and fade-out."""
        w, h = img.size
        display_frames = 50  # ~1.67s at 30fps
        local_frame = frame - who_will_win_frame
        if local_frame < 0 or local_frame > display_frames:
            return img

        font = self._get_font(96)
        text = "WHO WILL WIN?! 🤔"

        # Scale-in bounce for first 15 frames, then fade out in last 15
        scale_progress = min(1.0, local_frame / 15.0)
        scale = MathUtils.ease_out_bounce(scale_progress)
        fade_out = 1.0 if local_frame < display_frames - 15 else \
            1.0 - (local_frame - (display_frames - 15)) / 15.0
        alpha = int(255 * fade_out)

        # Screen dim overlay
        dim_overlay = Image.new("RGBA", img.size, (0, 0, 0, 0))
        dim_draw = ImageDraw.Draw(dim_overlay)
        dim_draw.rectangle([0, 0, w, h], fill=(0, 0, 0, int(80 * fade_out)))
        img = Image.alpha_composite(img, dim_overlay)
        draw = ImageDraw.Draw(img)

        bbox = draw.textbbox((0, 0), text, font=font)
        tw = int((bbox[2] - bbox[0]) * scale)
        th = int((bbox[3] - bbox[1]) * scale)
        tx = (w - tw) // 2
        ty = int(h * 0.18)

        fill_color = (255, 224, 0)
        outline_color = (0, 0, 0)
        outline_width = 4

        # Draw outline then fill using 8-direction offsets
        for dx in range(-outline_width, outline_width + 1):
            for dy in range(-outline_width, outline_width + 1):
                if dx * dx + dy * dy <= outline_width * outline_width:
                    draw.text(
                        (tx + int(dx * scale), ty + int(dy * scale)),
                        text, font=font,
                        fill=outline_color + (alpha,)
                    )
        draw.text((tx, ty), text, font=font, fill=fill_color + (alpha,))

        return img

    def render_go_callout(self, img: Image.Image, frame: int) -> Image.Image:
