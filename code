    def __init__(self, config: AnimationConfig):
        self.config = config
        self.sprite_w = config.sprite_width
        self.sprite_h = config.sprite_height

    def generate_character_sprites(
        self, template: Dict[str, Any], seed: int = 0
    ) -> Dict[str, List[Image.Image]]:
        """
        Generate all animation frames for a character.
        Returns dict with keys: 'run', 'idle', 'celebrate'
        Each value is a list of PIL Image frames (RGBA).
        """
        rng = random.Random(seed)
        sprites = {
            "run": [],
            "idle": [],
            "celebrate": [],
        }

        # Generate run cycle frames
        for frame_idx in range(self.config.run_cycle_frames):
            img = self._draw_character_frame(
                template, frame_idx, self.config.run_cycle_frames,
                animation_type="run", rng=rng
            )
            sprites["run"].append(img)

        # Generate idle frames
        for frame_idx in range(self.config.idle_frames):
            img = self._draw_character_frame(
                template, frame_idx, self.config.idle_frames,
                animation_type="idle", rng=rng
            )
            sprites["idle"].append(img)

        # Generate celebration frames
        for frame_idx in range(self.config.celebration_frames):
            img = self._draw_character_frame(
                template, frame_idx, self.config.celebration_frames,
                animation_type="celebrate", rng=rng
            )
            sprites["celebrate"].append(img)

        return sprites

    def _draw_character_frame(
        self,
        template: Dict[str, Any],
        frame_idx: int,
        total_frames: int,
        animation_type: str,
        rng: random.Random,
    ) -> Image.Image:
        """Draw a single frame of a character animation."""
        w, h = self.sprite_w, self.sprite_h
        img = Image.new("RGBA", (w, h), (0, 0, 0, 0))
        draw = ImageDraw.Draw(img)

        body_color = template["body_color"]
        accent_color = template["accent_color"]
        body_shape = template["body_shape"]

        # Animation phase (0.0 to 1.0)
        phase = frame_idx / max(1, total_frames)

        # --- BODY ---
        body_cx = w // 2
        body_cy = int(h * 0.55)

        # Body dimensions based on shape
        shape_params = {
            "round": (38, 42), "tall": (30, 50), "medium": (34, 44),
            "chunky": (44, 40), "wide": (46, 38), "slim": (26, 48),
            "suave": (32, 46),
        }
        body_rx, body_ry = shape_params.get(body_shape, (34, 44))

        # Running bounce
        bounce_y = 0
        lean_x = 0
        if animation_type == "run":
            bounce_y = int(math.sin(phase * 2 * math.pi) * 6)
            lean_x = int(math.sin(phase * 2 * math.pi) * 3)
        elif animation_type == "celebrate":
            bounce_y = int(abs(math.sin(phase * 4 * math.pi)) * 14)
        elif animation_type == "idle":
            bounce_y = int(math.sin(phase * 2 * math.pi) * 2)

        by = body_cy + bounce_y

        # Body shadow
        shadow_color = ColorUtils.darken(body_color, 0.4) + (80,)
        draw.ellipse(
            [body_cx - body_rx - 4 + lean_x, by - body_ry + 8,
             body_cx + body_rx + 4 + lean_x, by + body_ry + 8],
            fill=shadow_color,
        )

        # Main body
        draw.ellipse(
            [body_cx - body_rx + lean_x, by - body_ry,
             body_cx + body_rx + lean_x, by + body_ry],
            fill=body_color + (255,),
            outline=ColorUtils.darken(body_color, 0.6) + (255,),
            width=2,
        )

        # Body highlight
        highlight_color = ColorUtils.brighten(body_color, 1.4) + (100,)
        draw.ellipse(
            [body_cx - body_rx // 2 + lean_x - 5,
             by - body_ry + 5,
             body_cx + lean_x + 5,
             by - body_ry // 2 + 5],
            fill=highlight_color,
        )

        # --- HEAD ---
        head_cx = body_cx + lean_x
        head_cy = by - body_ry - 18
        head_r = 24

        # Head shadow
        draw.ellipse(
            [head_cx - head_r - 2, head_cy - head_r + 3,
             head_cx + head_r + 2, head_cy + head_r + 3],
            fill=ColorUtils.darken(body_color, 0.4) + (60,),
        )

