class EventType(Enum):
    """Types of random events."""
    BIRD_FLOCK = auto()
    CAMERA_SHAKE = auto()
    SPEED_BOOST = auto()
    CONFETTI_BURST = auto()
    LIGHTNING_FLASH = auto()
    DUST_CLOUD = auto()
    SCREEN_FLASH = auto()
    FALLING_STAR = auto()
    SPEED_LINES = auto()

@dataclass
class GameEvent:
    """Represents an active random event."""
    event_type: EventType
    start_frame: int
    duration_frames: int
    data: Dict[str, Any] = field(default_factory=dict)
    active: bool = True

    @property
    def age(self) -> int:
        return self.data.get("current_frame", 0) - self.start_frame

    @property
    def progress(self) -> float:
        age = self.age
        return min(1.0, age / max(1, self.duration_frames))


class RandomEventEngine:
    """
    Engine for generating and managing random events during the race.
    Events are visual or gameplay effects that add excitement.
    """

    def __init__(self, config: MasterConfig, rng: random.Random):
        self.config = config
        self.ec = config.event
        self.rng = rng
        self.active_events: List[GameEvent] = []
        self.event_history: List[GameEvent] = []
        self.particles: List[Dict[str, Any]] = []

    def update(self, state: RaceState) -> List[GameEvent]:
        """Update events for current frame. Returns list of active events."""
        if not self.ec.events_enabled:
            return []

        if state.phase != RacePhase.RACING:
            # Only generate events during racing
            self._update_existing_events(state)
            return self.active_events

        # Try to spawn new events
        if len(self.active_events) < self.ec.max_concurrent_events:
            self._try_spawn_events(state)

        # Update existing
        self._update_existing_events(state)

        # Update particles
        self._update_particles()

        return self.active_events

    def _try_spawn_events(self, state: RaceState):
        """Attempt to spawn new random events."""
        frame = state.frame_number

        # Bird flock
        if self.rng.random() < self.ec.bird_flock_chance:
            self._spawn_bird_flock(frame)

        # Camera shake
        if self.rng.random() < self.ec.camera_shake_chance:
            self._spawn_camera_shake(frame)

        # Speed boost (affects random character)
        if self.rng.random() < self.ec.speed_boost_chance:
            self._spawn_speed_boost(frame, state)

        # Confetti
        if self.rng.random() < self.ec.confetti_chance:
            self._spawn_confetti(frame)

        # Lightning
        if self.rng.random() < self.ec.lightning_chance:
            self._spawn_lightning(frame)

        # Dust clouds
        if self.rng.random() < self.ec.dust_cloud_chance:
            self._spawn_dust_cloud(frame, state)

        # Speed lines
        if self.rng.random() < 0.01:
            self._spawn_speed_lines(frame)

    def _spawn_bird_flock(self, frame: int):
        """Spawn a flock of birds flying across the screen."""
        birds = []
        count = self.rng.randint(3, 8)
        start_x = self.rng.choice([-50, self.config.video.width + 50])
        direction = 1 if start_x < 0 else -1
        for i in range(count):
            birds.append({
                "x": start_x + self.rng.randint(-30, 30),
                "y": self.rng.randint(50, 400),
                "speed": self.rng.uniform(4, 8) * direction,
                "wing_phase": self.rng.uniform(0, 2 * math.pi),
                "size": self.rng.randint(8, 16),
            })
        event = GameEvent(
            event_type=EventType.BIRD_FLOCK,
            start_frame=frame,
            duration_frames=90,
            data={"birds": birds},
        )
        self.active_events.append(event)

    def _spawn_camera_shake(self, frame: int):
        """Spawn a camera shake effect."""
        event = GameEvent(
            event_type=EventType.CAMERA_SHAKE,
            start_frame=frame,
            duration_frames=self.rng.randint(10, 25),
            data={
                "intensity": self.rng.uniform(3, 10),
                "frequency": self.rng.uniform(1, 3),
            },
        )
        self.active_events.append(event)

    def _spawn_speed_boost(self, frame: int, state: RaceState):
        """Give a random character a speed boost."""
        if not state.characters:
            return
        target = self.rng.choice(state.characters)
        event = GameEvent(
            event_type=EventType.SPEED_BOOST,
            start_frame=frame,
            duration_frames=20,
            data={"target_name": target.name, "multiplier": 1.5},
        )
        target.is_boosting = True
        target.boost_frames_left = 20
        self.active_events.append(event)

    def _spawn_confetti(self, frame: int):
        """Spawn confetti particles."""
        confetti_pieces = []
        for _ in range(30):
            confetti_pieces.append({
                "x": self.rng.randint(0, self.config.video.width),
                "y": self.rng.randint(-50, -10),
                "vx": self.rng.uniform(-2, 2),
                "vy": self.rng.uniform(2, 6),
                "rotation": self.rng.uniform(0, 360),
                "rot_speed": self.rng.uniform(-10, 10),
                "color": ColorUtils.random_vibrant(),
                "size": self.rng.randint(4, 10),
            })
        event = GameEvent(
            event_type=EventType.CONFETTI_BURST,
            start_frame=frame,
            duration_frames=60,
            data={"particles": confetti_pieces},
        )
        self.active_events.append(event)

    def _spawn_lightning(self, frame: int):
        """Spawn a lightning flash effect."""
        event = GameEvent(
            event_type=EventType.LIGHTNING_FLASH,
            start_frame=frame,
            duration_frames=8,
            data={"intensity": self.rng.uniform(0.5, 1.0)},
        )
        self.active_events.append(event)

    def _spawn_dust_cloud(self, frame: int, state: RaceState):
        """Spawn dust clouds behind characters."""
        if not state.characters:
            return
        char = self.rng.choice(state.characters)
        dust_parts = []
        for _ in range(10):
            dust_parts.append({
                "x": 0, "y": 0,
                "vx": self.rng.uniform(-3, -0.5),
                "vy": self.rng.uniform(-2, 2),
                "size": self.rng.uniform(5, 15),
                "alpha": 200,
                "fade_rate": self.rng.uniform(5, 15),
            })
        event = GameEvent(
            event_type=EventType.DUST_CLOUD,
            start_frame=frame,
            duration_frames=30,
            data={"character_lane": char.lane, "particles": dust_parts},
        )
        self.active_events.append(event)

    def _spawn_speed_lines(self, frame: int):
        """Spawn speed lines effect."""
        lines = []
        for _ in range(15):
            lines.append({
                "x": self.rng.randint(0, self.config.video.width),
                "y": self.rng.randint(0, self.config.video.height),
                "length": self.rng.randint(30, 100),
                "speed": self.rng.uniform(10, 25),
                "alpha": self.rng.randint(50, 150),
                "thickness": self.rng.randint(1, 3),
            })
        event = GameEvent(
            event_type=EventType.SPEED_LINES,
            start_frame=frame,
            duration_frames=20,
            data={"lines": lines},
        )
        self.active_events.append(event)

    def _update_existing_events(self, state: RaceState):
        """Update all active events and remove expired ones."""
        frame = state.frame_number
        still_active = []

        for event in self.active_events:
            event.data["current_frame"] = frame
            age = frame - event.start_frame

            if age >= event.duration_frames:
                event.active = False
                self.event_history.append(event)
                continue

            # Update event-specific data
            if event.event_type == EventType.BIRD_FLOCK:
                for bird in event.data.get("birds", []):
                    bird["x"] += bird["speed"]
                    bird["wing_phase"] += 0.3

            elif event.event_type == EventType.CAMERA_SHAKE:
                intensity = event.data["intensity"]
                decay = 1.0 - (age / event.duration_frames)
                freq = event.data["frequency"]
                state.camera_shake = (
                    math.sin(age * freq) * intensity * decay,
                    math.cos(age * freq * 1.3) * intensity * decay * 0.7,
                )

            elif event.event_type == EventType.CONFETTI_BURST:
                for p in event.data.get("particles", []):
                    p["x"] += p["vx"]
                    p["y"] += p["vy"]
                    p["vy"] += 0.1  # gravity
                    p["rotation"] += p["rot_speed"]

            elif event.event_type == EventType.DUST_CLOUD:
                for p in event.data.get("particles", []):
                    p["x"] += p["vx"]
                    p["y"] += p["vy"]
                    p["size"] += 0.3
                    p["alpha"] = max(0, p["alpha"] - p["fade_rate"])

            elif event.event_type == EventType.SPEED_LINES:
                for line in event.data.get("lines", []):
                    line["x"] -= line["speed"]
                    if line["x"] + line["length"] < 0:
                        line["x"] = self.config.video.width + self.rng.randint(0, 50)

            still_active.append(event)

        self.active_events = still_active

        # Reset camera shake if no shake events
        if not any(e.event_type == EventType.CAMERA_SHAKE for e in self.active_events):
            state.camera_shake = (
                state.camera_shake[0] * 0.8,
                state.camera_shake[1] * 0.8,
            )

    def _update_particles(self):
        """Update general particle system."""
        surviving = []
        for p in self.particles:
            p["x"] += p.get("vx", 0)
            p["y"] += p.get("vy", 0)
            p["vy"] = p.get("vy", 0) + p.get("gravity", 0.1)
            p["life"] = p.get("life", 1.0) - p.get("decay", 0.02)
            if p["life"] > 0:
                surviving.append(p)
        self.particles = surviving

    def get_camera_shake(self) -> Tuple[float, float]:
        """Get current camera shake offset."""
        for event in self.active_events:
            if event.event_type == EventType.CAMERA_SHAKE:
                return (
                    self.rng.gauss(0, event.data["intensity"] *
                                   (1 - event.progress)),
                    self.rng.gauss(0, event.data["intensity"] *
                                   (1 - event.progress) * 0.7),
                )
        return (0.0, 0.0)

