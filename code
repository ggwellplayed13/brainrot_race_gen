@dataclass
class CharacterStats:
    """Statistics defining character racing behavior."""
    base_speed: float = 1.0
    acceleration: float = 0.5
    stamina: float = 1.0
    burst_chance: float = 0.03
    burst_power: float = 2.0
    consistency: float = 0.7
    recovery_rate: float = 0.02
    jump_power: float = 1.0
    weight: float = 1.0

    def randomize(self, rng: random.Random, variance: float = 0.3):
        """Add random variance to stats."""
        self.base_speed *= rng.uniform(1 - variance, 1 + variance)
        self.acceleration *= rng.uniform(1 - variance, 1 + variance)
        self.stamina *= rng.uniform(1 - variance, 1 + variance)
        self.burst_chance *= rng.uniform(0.5, 1.5)
        self.burst_power *= rng.uniform(0.8, 1.2)
        self.consistency *= rng.uniform(0.8, 1.0)
        self.recovery_rate *= rng.uniform(0.8, 1.2)
        return self


class Character:
    """
    Represents a single racing character with sprites, stats, and state.
    """

    def __init__(
        self,
        name: str,
        template: Dict[str, Any],
        stats: CharacterStats,
        lane: int,
        sprites: Dict[str, List[Image.Image]],
    ):
        self.name = name
        self.template = template
        self.stats = stats
        self.lane = lane
        self.sprites = sprites

        # Race state
        self.position: float = 0.0       # 0.0 to 1.0 (start to finish)
        self.velocity: float = 0.0
        self.current_speed: float = 0.0
        self.stamina_current: float = stats.stamina
        self.is_boosting: bool = False
        self.boost_frames_left: int = 0
        self.finished: bool = False
        self.finish_time: float = -1.0
        self.placement: int = 0

        # Animation state
        self.current_animation: str = "idle"
        self.animation_frame: int = 0
        self.animation_timer: float = 0.0
        self.screen_x: float = 0.0
        self.screen_y: float = 0.0
        self.scale: float = 1.0
        self.rotation: float = 0.0
        self.flip_h: bool = False
        self.alpha: float = 1.0
        self.effect_particles: List[Dict] = []

        # History for trails/effects
        self.position_history: List[float] = []
        self.speed_history: List[float] = []

    def get_current_sprite(self) -> Image.Image:
        """Get the current animation frame sprite."""
        anim_frames = self.sprites.get(self.current_animation, self.sprites.get("idle", []))
        if not anim_frames:
            # Fallback: create empty sprite
            return Image.new("RGBA", (140, 180), (255, 0, 255, 128))
        frame_idx = self.animation_frame % len(anim_frames)
        return anim_frames[frame_idx]

    def advance_animation(self, dt: float, anim_speed: float = 0.15):
        """Advance the animation timer and update frame."""
        self.animation_timer += dt
        speed_factor = max(0.5, self.current_speed * 2)
        effective_speed = anim_speed / speed_factor
        if self.animation_timer >= effective_speed:
            self.animation_timer = 0.0
            anim_frames = self.sprites.get(self.current_animation, [])
            if anim_frames:
                self.animation_frame = (self.animation_frame + 1) % len(anim_frames)

    def set_animation(self, anim_name: str):
        """Switch to a different animation."""
        if anim_name != self.current_animation:
            self.current_animation = anim_name
            self.animation_frame = 0
            self.animation_timer = 0.0

    def __repr__(self):
        return (
            f"Character('{self.name}', lane={self.lane}, "
            f"pos={self.position:.3f}, speed={self.current_speed:.4f})"
        )


class CharacterFactory:
    """Factory for creating racing characters with procedural generation."""

    def __init__(self, config: MasterConfig):
        self.config = config
        self.sprite_gen = ProceduralCharacterGenerator(config.animation)
        self._template_pool = list(ProceduralCharacterGenerator.CHARACTER_TEMPLATES)

    def create_characters(
        self, count: int, rng: random.Random
    ) -> List[Character]:
        """Create a set of unique racing characters."""
        # Shuffle and pick templates
        available = list(self._template_pool)
        rng.shuffle(available)
        selected = available[:count]

        characters = []
        for i, template in enumerate(selected):
            # Generate stats
            stats = CharacterStats()
            stats.base_speed = self.config.race.base_speed
            stats.randomize(rng, variance=0.25)

            # Generate sprites
            sprite_seed = rng.randint(0, 100000)
            sprites = self.sprite_gen.generate_character_sprites(template, sprite_seed)

            char = Character(
                name=template["name"],
                template=template,
                stats=stats,
                lane=i,
                sprites=sprites,
            )
            characters.append(char)
            log.info(f"  Created character: {char.name} (lane {i}, "
                     f"speed={stats.base_speed:.4f})")

        return characters

