            self._draw_outlined_text(draw, (panel_x + 85, cy + 2), char.name, font_name,
                                     fill_color=(255, 255, 255), outline_width=2)

            bar_x = panel_x + 85
            bar_y = cy + 26
            bar_w = 180
            bar_h = 6
            draw.rectangle([bar_x, bar_y, bar_x + bar_w, bar_y + bar_h],
