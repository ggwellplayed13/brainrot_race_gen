            [head_cx - head_r, head_cy - head_r,
             head_cx + head_r, head_cy + head_r],
            fill=body_color + (255,),
            outline=ColorUtils.darken(body_color, 0.6) + (255,),
            width=2,
        )

        # Head highlight
        draw.ellipse(
            [head_cx - head_r // 2 - 4, head_cy - head_r + 3,
             head_cx + 2, head_cy - head_r // 2 + 3],
            fill=ColorUtils.brighten(body_color, 1.5) + (80,),
        )

        # --- EYES ---
        self._draw_eyes(draw, head_cx, head_cy, head_r, template["eye_style"],
                        phase, animation_type)

        # --- MOUTH ---
