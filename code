    def __init__(self, config: AnimationConfig):
        self.config = config
        self.sprite_w = config.sprite_width
        self.sprite_h = config.sprite_height

    def generate_character_sprites(
        self, template: Dict[str, Any], seed: int = 0
    ) -> Dict[str, List[Image.Image]]:
        """
        Generate all animation frames for a character.
        Returns dict with keys: 'run', 'idle', 'celebrate'
        Each value is a list of PIL Image frames (RGBA).
        """
        rng = random.Random(seed)
        sprites = {
            "run": [],
            "idle": [],
            "celebrate": [],
        }

        # Generate run cycle frames
        for frame_idx in range(self.config.run_cycle_frames):
            img = self._draw_character_frame(
                template, frame_idx, self.config.run_cycle_frames,
                animation_type="run", rng=rng
            )
            sprites["run"].append(img)

        # Generate idle frames
        for frame_idx in range(self.config.idle_frames):
            img = self._draw_character_frame(
                template, frame_idx, self.config.idle_frames,
                animation_type="idle", rng=rng
            )
            sprites["idle"].append(img)

        # Generate celebration frames
        for frame_idx in range(self.config.celebration_frames):
            img = self._draw_character_frame(
                template, frame_idx, self.config.celebration_frames,
                animation_type="celebrate", rng=rng
            )
            sprites["celebrate"].append(img)

        return sprites

    def _draw_character_frame(
        self,
        template: Dict[str, Any],
        frame_idx: int,
        total_frames: int,
        animation_type: str,
        rng: random.Random,
    ) -> Image.Image:
        """Draw a single frame of a character animation."""
        w, h = self.sprite_w, self.sprite_h
        img = Image.new("RGBA", (w, h), (0, 0, 0, 0))
        draw = ImageDraw.Draw(img)

        body_color = template["body_color"]
        accent_color = template["accent_color"]
        body_shape = template["body_shape"]

        # Animation phase (0.0 to 1.0)
        phase = frame_idx / max(1, total_frames)

        # --- BODY ---
        body_cx = w // 2
        body_cy = int(h * 0.55)

        # Body dimensions based on shape
        shape_params = {
            "round": (38, 42), "tall": (30, 50), "medium": (34, 44),
            "chunky": (44, 40), "wide": (46, 38), "slim": (26, 48),
            "suave": (32, 46),
        }
        body_rx, body_ry = shape_params.get(body_shape, (34, 44))

        # Running bounce
        bounce_y = 0
        lean_x = 0
        if animation_type == "run":
            bounce_y = int(math.sin(phase * 2 * math.pi) * 14)
            lean_x = int(math.sin(phase * 2 * math.pi) * 8)
        elif animation_type == "celebrate":
            bounce_y = int(abs(math.sin(phase * 6 * math.pi)) * self.config.celebration_jump_height)
        elif animation_type == "idle":
            bounce_y = int(math.sin(phase * 2 * math.pi) * 2)

        by = body_cy + bounce_y

        # Body shadow
        shadow_color = ColorUtils.darken(body_color, 0.4) + (80,)
        draw.ellipse(
            [body_cx - body_rx - 4 + lean_x, by - body_ry + 8,
             body_cx + body_rx + 4 + lean_x, by + body_ry + 8],
            fill=shadow_color,
        )

        # Main body
        draw.ellipse(
            [body_cx - body_rx + lean_x, by - body_ry,
             body_cx + body_rx + lean_x, by + body_ry],
            fill=body_color + (255,),
            outline=ColorUtils.darken(body_color, 0.6) + (255,),
            width=2,
        )

        # Body highlight
        highlight_color = ColorUtils.brighten(body_color, 1.4) + (100,)
        draw.ellipse(
            [body_cx - body_rx // 2 + lean_x - 5,
             by - body_ry + 5,
             body_cx + lean_x + 5,
             by - body_ry // 2 + 5],
            fill=highlight_color,
        )

        # --- HEAD ---
        head_cx = body_cx + lean_x
        head_cy = by - body_ry - 18
        head_r = 30

        # Head shadow
        draw.ellipse(
            [head_cx - head_r - 2, head_cy - head_r + 3,
             head_cx + head_r + 2, head_cy + head_r + 3],
            fill=ColorUtils.darken(body_color, 0.4) + (60,),
        )

        # Head
        draw.ellipse(
            [head_cx - head_r, head_cy - head_r,
             head_cx + head_r, head_cy + head_r],
            fill=body_color + (255,),
            outline=ColorUtils.darken(body_color, 0.6) + (255,),
            width=2,
        )

        # Head highlight
        draw.ellipse(
            [head_cx - head_r // 2 - 4, head_cy - head_r + 3,
             head_cx + 2, head_cy - head_r // 2 + 3],
            fill=ColorUtils.brighten(body_color, 1.5) + (80,),
        )

        # --- EYES ---
        self._draw_eyes(draw, head_cx, head_cy, head_r, template["eye_style"],
                        phase, animation_type)

        # --- MOUTH ---
        self._draw_mouth(draw, head_cx, head_cy + 8, template["expression"],
                         phase, animation_type)

        # --- LEGS ---
        self._draw_legs(draw, body_cx + lean_x, by + body_ry - 5,
                        body_color, phase, animation_type)

        # --- ARMS ---
        self._draw_arms(draw, body_cx + lean_x, by - body_ry // 3,
                        body_rx, body_color, phase, animation_type)

        # --- ACCESSORY ---
        self._draw_accessory(draw, head_cx, head_cy, head_r,
                             template["accessory"], accent_color, phase, animation_type)

        return img

    def _draw_eyes(
        self, draw: ImageDraw.Draw,
        cx: int, cy: int, head_r: int,
        eye_style: str, phase: float, anim_type: str
    ):
        """Draw character eyes based on style."""
        eye_y = cy - 3
        eye_left_x = cx - 12
        eye_right_x = cx + 12
        eye_size = 10

        white = (255, 255, 255, 255)
        black = (20, 20, 20, 255)
        pupil_offset_x = int(math.sin(phase * 2 * math.pi) * 2) if anim_type == "run" else 0

        if eye_style == "angry":
            # Angry eyebrows
            for ex in [eye_left_x, eye_right_x]:
                draw.ellipse([ex - eye_size, eye_y - eye_size,
                              ex + eye_size, eye_y + eye_size], fill=white)
                draw.ellipse([ex - 3 + pupil_offset_x, eye_y - 3,
                              ex + 3 + pupil_offset_x, eye_y + 3], fill=black)
            # Angry brows
            draw.line([eye_left_x - 8, eye_y - 10, eye_left_x + 5, eye_y - 7],
                      fill=black, width=3)
            draw.line([eye_right_x + 8, eye_y - 10, eye_right_x - 5, eye_y - 7],
                      fill=black, width=3)

        elif eye_style == "cool":
            for ex in [eye_left_x, eye_right_x]:
                draw.ellipse([ex - eye_size, eye_y - eye_size // 2,
                              ex + eye_size, eye_y + eye_size // 2], fill=white)
                draw.ellipse([ex - 2 + pupil_offset_x, eye_y - 2,
                              ex + 2 + pupil_offset_x, eye_y + 2], fill=black)

        elif eye_style == "sparkle":
            for ex in [eye_left_x, eye_right_x]:
                draw.ellipse([ex - eye_size, eye_y - eye_size,
                              ex + eye_size, eye_y + eye_size], fill=white)
                draw.ellipse([ex - 4 + pupil_offset_x, eye_y - 4,
                              ex + 4 + pupil_offset_x, eye_y + 4], fill=(50, 50, 200, 255))
                # Sparkle
                sparkle_alpha = int(abs(math.sin(phase * 4 * math.pi)) * 200 + 55)
                draw.ellipse([ex - 2, eye_y - 6, ex + 2, eye_y - 4],
                             fill=(255, 255, 255, sparkle_alpha))

        elif eye_style == "wide":
            for ex in [eye_left_x, eye_right_x]:
                draw.ellipse([ex - eye_size - 2, eye_y - eye_size - 2,
                              ex + eye_size + 2, eye_y + eye_size + 2], fill=white)
                draw.ellipse([ex - 4 + pupil_offset_x, eye_y - 4,
                              ex + 4 + pupil_offset_x, eye_y + 4], fill=black)

        elif eye_style == "intense":
            for ex in [eye_left_x, eye_right_x]:
                draw.ellipse([ex - eye_size, eye_y - eye_size,
                              ex + eye_size, eye_y + eye_size], fill=white)
                draw.ellipse([ex - 3 + pupil_offset_x, eye_y - 3,
                              ex + 3 + pupil_offset_x, eye_y + 3], fill=(200, 0, 0, 255))
                # Glow
                draw.ellipse([ex - 1, eye_y - 1, ex + 1, eye_y + 1],
                             fill=(255, 200, 0, 200))

        elif eye_style == "focused":
            for ex in [eye_left_x, eye_right_x]:
                draw.ellipse([ex - eye_size + 1, eye_y - eye_size,
                              ex + eye_size - 1, eye_y + eye_size], fill=white)
                draw.ellipse([ex - 2 + pupil_offset_x, eye_y - 3,
                              ex + 2 + pupil_offset_x, eye_y + 3], fill=black)

        elif eye_style == "wink":
            # Left eye normal
            draw.ellipse([eye_left_x - eye_size, eye_y - eye_size,
                          eye_left_x + eye_size, eye_y + eye_size], fill=white)
            draw.ellipse([eye_left_x - 3 + pupil_offset_x, eye_y - 3,
                          eye_left_x + 3 + pupil_offset_x, eye_y + 3], fill=black)
            # Right eye wink (line)
            wink_phase = math.sin(phase * 2 * math.pi)
            if wink_phase > 0.3:
                draw.line([eye_right_x - 6, eye_y, eye_right_x + 6, eye_y],
                          fill=black, width=3)
            else:
                draw.ellipse([eye_right_x - eye_size, eye_y - eye_size,
                              eye_right_x + eye_size, eye_y + eye_size], fill=white)
                draw.ellipse([eye_right_x - 3, eye_y - 3,
                              eye_right_x + 3, eye_y + 3], fill=black)

        elif eye_style == "fierce":
            for ex in [eye_left_x, eye_right_x]:
                # Cat-like eyes
                draw.ellipse([ex - eye_size, eye_y - eye_size + 2,
                              ex + eye_size, eye_y + eye_size - 2], fill=white)
                draw.ellipse([ex - 2 + pupil_offset_x, eye_y - 4,
                              ex + 2 + pupil_offset_x, eye_y + 4], fill=(0, 150, 0, 255))
                # Slit pupil
                draw.line([ex + pupil_offset_x, eye_y - 3,
                           ex + pupil_offset_x, eye_y + 3], fill=black, width=2)

        elif eye_style == "crazy":
            # One eye bigger than the other, pupils pointing different directions
            left_size = eye_size + 4
            right_size = eye_size - 2
            draw.ellipse([eye_left_x - left_size, eye_y - left_size,
                          eye_left_x + left_size, eye_y + left_size], fill=white)
            draw.ellipse([eye_left_x - 4, eye_y - 6, eye_left_x + 4, eye_y + 2],
                         fill=(200, 0, 200, 255))
            draw.ellipse([eye_right_x - right_size, eye_y - right_size,
                          eye_right_x + right_size, eye_y + right_size], fill=white)
            draw.ellipse([eye_right_x + 1, eye_y + 1, eye_right_x + 5, eye_y + 5],
                         fill=(0, 180, 200, 255))
            # Crazy swirl marks
            draw.arc([eye_left_x - 3, eye_y - 3, eye_left_x + 3, eye_y + 3],
                     0, 270, fill=black, width=1)

        elif eye_style == "dreamy":
            # Half-closed eyes with stars in pupils
            for ex in [eye_left_x, eye_right_x]:
                # Half-closed: only bottom half visible
                draw.ellipse([ex - eye_size, eye_y - eye_size,
                              ex + eye_size, eye_y + eye_size], fill=white)
                # Heavy eyelid (top half covered)
                draw.ellipse([ex - eye_size - 1, eye_y - eye_size - 1,
                              ex + eye_size + 1, eye_y], fill=(180, 140, 200, 255))
                # Star in pupil
                star_size = 4
                for j in range(4):
                    angle = j * math.pi / 2 + frame * 0.05
                    sx = ex + int(math.cos(angle) * star_size)
                    sy = eye_y + 3 + int(math.sin(angle) * star_size)
                    draw.ellipse([sx - 1, sy - 1, sx + 1, sy + 1],
                                 fill=(255, 220, 50, 230))
                draw.ellipse([ex - 2, eye_y + 1, ex + 2, eye_y + 5],
                             fill=(80, 0, 120, 255))

        else:
            # Default eyes
            for ex in [eye_left_x, eye_right_x]:
                draw.ellipse([ex - eye_size, eye_y - eye_size,
                              ex + eye_size, eye_y + eye_size], fill=white)
                draw.ellipse([ex - 3 + pupil_offset_x, eye_y - 3,
                              ex + 3 + pupil_offset_x, eye_y + 3], fill=black)

    def _draw_mouth(
        self, draw: ImageDraw.Draw,
        cx: int, cy: int,
        expression: str, phase: float, anim_type: str
    ):
        """Draw character mouth based on expression."""
        mouth_y = cy + 4

        if expression in ("determined", "powerful"):
            # Gritted teeth / determined line
            draw.line([cx - 8, mouth_y, cx + 8, mouth_y],
                      fill=(20, 20, 20, 255), width=2)
            if anim_type == "celebrate":
                draw.arc([cx - 10, mouth_y - 4, cx + 10, mouth_y + 8],
                         0, 180, fill=(20, 20, 20, 255), width=2)

        elif expression in ("excited", "charming"):
            # Big open smile
            draw.arc([cx - 10, mouth_y - 6, cx + 10, mouth_y + 6],
                     0, 180, fill=(20, 20, 20, 255), width=2)
            draw.arc([cx - 8, mouth_y - 2, cx + 8, mouth_y + 6],
                     0, 180, fill=(200, 80, 80, 255), width=4)

        elif expression == "stoic":
            draw.line([cx - 6, mouth_y, cx + 6, mouth_y],
                      fill=(20, 20, 20, 255), width=2)

        elif expression == "hungry":
            # Open mouth
            mouth_open = int(abs(math.sin(phase * 3 * math.pi)) * 5) + 2
            draw.ellipse([cx - 7, mouth_y - 2, cx + 7, mouth_y + mouth_open + 3],
                         fill=(150, 40, 40, 255), outline=(20, 20, 20, 255), width=1)

        elif expression == "concentrated":
            # Small focused mouth
            draw.line([cx - 4, mouth_y + 1, cx + 4, mouth_y - 1],
                      fill=(20, 20, 20, 255), width=2)

        elif expression == "fierce":
            # Smirk
            draw.arc([cx - 8, mouth_y - 8, cx + 8, mouth_y + 4],
                     20, 160, fill=(20, 20, 20, 255), width=2)

        elif expression == "manic":
            # Huge zigzag grin
            pts = []
            steps = 8
            for i in range(steps + 1):
                t = i / steps
                mx = int(cx - 14 + 28 * t)
                my = mouth_y + (0 if i % 2 == 0 else 8)
                pts.append((mx, my))
            for i in range(len(pts) - 1):
                draw.line([pts[i], pts[i + 1]], fill=(20, 20, 20, 255), width=2)

        elif expression == "chill":
            # Slight smirk
            draw.arc([cx - 5, mouth_y - 2, cx + 10, mouth_y + 6],
                     10, 170, fill=(20, 20, 20, 255), width=2)

        elif expression == "surprised":
            # Perfect O mouth
            mouth_r = 5 + int(abs(math.sin(phase * 2 * math.pi)) * 2)
            draw.ellipse([cx - mouth_r, mouth_y - mouth_r,
                          cx + mouth_r, mouth_y + mouth_r],
                         fill=(150, 40, 40, 255), outline=(20, 20, 20, 255), width=2)

        elif expression == "cosmic":
            # Wavy mouth with sparkle dots
            draw.arc([cx - 8, mouth_y - 4, cx + 8, mouth_y + 4],
                     0, 180, fill=(20, 20, 20, 255), width=2)
            sparkle_alpha = int(abs(math.sin(phase * 4 * math.pi)) * 200 + 55)
            for sx in [cx - 6, cx, cx + 6]:
                draw.ellipse([sx - 1, mouth_y - 7, sx + 1, mouth_y - 5],
                             fill=(255, 220, 50, sparkle_alpha))

        elif expression == "dizzy":
            # Spiral-ish wiggly mouth
            pts = []
            for i in range(9):
                t = i / 8
                mx = int(cx - 10 + 20 * t)
                my = int(mouth_y + math.sin(t * 3 * math.pi) * 4)
                pts.append((mx, my))
            for i in range(len(pts) - 1):
                draw.line([pts[i], pts[i + 1]], fill=(20, 20, 20, 255), width=2)

        elif expression == "playful":
            # Tongue sticking out
            draw.arc([cx - 8, mouth_y - 4, cx + 8, mouth_y + 4],
                     0, 180, fill=(20, 20, 20, 255), width=2)
            draw.ellipse([cx - 5, mouth_y + 2, cx + 5, mouth_y + 10],
                         fill=(255, 100, 120, 230), outline=(20, 20, 20, 200), width=1)

        elif expression == "floaty":
            # Gentle wavy smile
            pts = []
            for i in range(7):
                t = i / 6
                mx = int(cx - 10 + 20 * t)
                my = int(mouth_y + math.sin(t * 2 * math.pi) * 3 + 2)
                pts.append((mx, my))
            for i in range(len(pts) - 1):
                draw.line([pts[i], pts[i + 1]], fill=(20, 20, 20, 255), width=2)

        else:
            # Default small smile
            draw.arc([cx - 6, mouth_y - 4, cx + 6, mouth_y + 4],
                     0, 180, fill=(20, 20, 20, 255), width=2)

    def _draw_legs(
        self, draw: ImageDraw.Draw,
        cx: int, top_y: int,
        body_color: Tuple[int, int, int],
        phase: float, anim_type: str
    ):
        """Draw character legs with run animation."""
        leg_color = ColorUtils.darken(body_color, 0.7)
        shoe_color = (40, 40, 40, 255)
        leg_len = 30

        if anim_type == "run":
            # Running legs alternate
            left_angle = math.sin(phase * 2 * math.pi) * 40
            right_angle = math.sin(phase * 2 * math.pi + math.pi) * 40

            for angle, offset_x in [(left_angle, -12), (right_angle, 12)]:
                rad = math.radians(angle)
                end_x = cx + offset_x + int(math.sin(rad) * leg_len)
                end_y = top_y + int(math.cos(rad) * leg_len)
                # Leg
                draw.line([cx + offset_x, top_y, end_x, end_y],
                          fill=leg_color + (255,), width=8)
                # Shoe
                draw.ellipse([end_x - 8, end_y - 4, end_x + 8, end_y + 6],
                             fill=shoe_color)

        elif anim_type == "celebrate":
            # Jumping/celebration pose
            spread = int(abs(math.sin(phase * 3 * math.pi)) * 20) + 10
            for sign in [-1, 1]:
                end_x = cx + sign * spread
                end_y = top_y + leg_len - int(abs(math.sin(phase * 4 * math.pi)) * 10)
                draw.line([cx + sign * 8, top_y, end_x, end_y],
                          fill=leg_color + (255,), width=8)
                draw.ellipse([end_x - 8, end_y - 4, end_x + 8, end_y + 6],
                             fill=shoe_color)
        else:
            # Idle standing
            for offset_x in [-12, 12]:
                bob = int(math.sin(phase * 2 * math.pi) * 2)
                draw.line([cx + offset_x, top_y,
                           cx + offset_x, top_y + leg_len + bob],
                          fill=leg_color + (255,), width=8)
                draw.ellipse([cx + offset_x - 8, top_y + leg_len + bob - 4,
                              cx + offset_x + 8, top_y + leg_len + bob + 6],
                             fill=shoe_color)

    def _draw_arms(
        self, draw: ImageDraw.Draw,
        cx: int, cy: int, body_rx: int,
        body_color: Tuple[int, int, int],
        phase: float, anim_type: str
    ):
        """Draw character arms with animation."""
        arm_color = ColorUtils.darken(body_color, 0.8)
        hand_color = ColorUtils.brighten(body_color, 1.2)

        if anim_type == "run":
            left_swing = math.sin(phase * 2 * math.pi + math.pi) * 25
            right_swing = math.sin(phase * 2 * math.pi) * 25

            for swing, side in [(left_swing, -1), (right_swing, 1)]:
                start_x = cx + side * (body_rx - 5)
                rad = math.radians(swing)
                end_x = start_x + side * 10 + int(math.sin(rad) * 15)
                end_y = cy + 20 + int(math.cos(rad) * 10)
                draw.line([start_x, cy, end_x, end_y],
                          fill=arm_color + (255,), width=6)
                draw.ellipse([end_x - 5, end_y - 5, end_x + 5, end_y + 5],
                             fill=hand_color + (255,))

        elif anim_type == "celebrate":
            # Arms up celebration
            arm_up = abs(math.sin(phase * 4 * math.pi))
            for side in [-1, 1]:
                start_x = cx + side * (body_rx - 5)
                end_x = start_x + side * 20
                end_y = cy - 20 - int(arm_up * 25)
                draw.line([start_x, cy, end_x, end_y],
                          fill=arm_color + (255,), width=6)
                draw.ellipse([end_x - 5, end_y - 5, end_x + 5, end_y + 5],
                             fill=hand_color + (255,))
        else:
            # Idle arms at sides
            for side in [-1, 1]:
                start_x = cx + side * (body_rx - 5)
                bob = int(math.sin(phase * 2 * math.pi) * 3)
                draw.line([start_x, cy, start_x + side * 5, cy + 25 + bob],
                          fill=arm_color + (255,), width=6)
                draw.ellipse([start_x + side * 5 - 5, cy + 25 + bob - 5,
                              start_x + side * 5 + 5, cy + 25 + bob + 5],
                             fill=hand_color + (255,))

    def _draw_accessory(
        self, draw: ImageDraw.Draw,
        cx: int, cy: int, head_r: int,
        accessory: str,
        color: Tuple[int, int, int],
        phase: float, anim_type: str
    ):
        """Draw character accessory."""
        if accessory == "crown":
            crown_y = cy - head_r - 8
            points = [
                (cx - 16, crown_y + 10), (cx - 16, crown_y + 2),
                (cx - 10, crown_y + 6), (cx - 5, crown_y - 4),
                (cx, crown_y + 4), (cx + 5, crown_y - 4),
                (cx + 10, crown_y + 6), (cx + 16, crown_y + 2),
                (cx + 16, crown_y + 10),
            ]
            draw.polygon(points, fill=color + (255,),
                         outline=ColorUtils.darken(color, 0.6) + (255,))
            # Jewels
            for jx in [cx - 5, cx, cx + 5]:
                draw.ellipse([jx - 2, crown_y + 2, jx + 2, crown_y + 6],
                             fill=(255, 50, 50, 255))

        elif accessory == "sunglasses":
            glass_y = cy - 4
            for gx in [cx - 10, cx + 10]:
                draw.rectangle([gx - 10, glass_y - 5, gx + 10, glass_y + 5],
                               fill=(20, 20, 20, 230),
                               outline=(60, 60, 60, 255), width=1)
            draw.line([cx - 1, glass_y, cx + 1, glass_y],
                      fill=(60, 60, 60, 255), width=2)

        elif accessory == "hat":
            hat_y = cy - head_r - 2
            # Brim
            draw.ellipse([cx - 22, hat_y + 2, cx + 22, hat_y + 10],
                         fill=color + (255,))
            # Top
            draw.rectangle([cx - 14, hat_y - 14, cx + 14, hat_y + 6],
                           fill=color + (255,),
                           outline=ColorUtils.darken(color, 0.6) + (255,))
            draw.line([cx - 14, hat_y, cx + 14, hat_y],
                      fill=ColorUtils.darken(color, 0.5) + (255,), width=3)

        elif accessory == "headband":
            band_y = cy - head_r + 4
            draw.arc([cx - head_r - 2, band_y - 3,
                      cx + head_r + 2, band_y + head_r + 10],
                     200, 340, fill=color + (255,), width=5)

        elif accessory == "cape":
            # Cape flowing behind
            cape_top_y = cy + head_r - 10
            flow = math.sin(phase * 3 * math.pi) * 8
            cape_points = [
                (cx - 18, cape_top_y),
                (cx + 18, cape_top_y),
                (cx + 22 + int(flow), cape_top_y + 50),
                (cx - 22 + int(flow), cape_top_y + 50),
            ]
            draw.polygon(cape_points, fill=color + (180,),
                         outline=ColorUtils.darken(color, 0.5) + (200,))

        elif accessory == "band":
            # Wristband-style band on head
            band_y = cy - head_r + 6
            draw.arc([cx - head_r, band_y,
                      cx + head_r, band_y + 12],
                     200, 340, fill=color + (255,), width=4)

        elif accessory == "bowtie":
            bow_y = cy + head_r + 2
            # Left triangle
            draw.polygon([(cx, bow_y), (cx - 10, bow_y - 6), (cx - 10, bow_y + 6)],
                         fill=color + (255,))
            # Right triangle
            draw.polygon([(cx, bow_y), (cx + 10, bow_y - 6), (cx + 10, bow_y + 6)],
                         fill=color + (255,))
            draw.ellipse([cx - 3, bow_y - 3, cx + 3, bow_y + 3],
                         fill=ColorUtils.darken(color, 0.7) + (255,))

        elif accessory == "tiara":
            tiara_y = cy - head_r - 4
            for i in range(5):
                px = cx - 12 + i * 6
                ph = 8 if i == 2 else (5 if i in (1, 3) else 3)
                draw.polygon(
                    [(px - 2, tiara_y + 4), (px, tiara_y - ph), (px + 2, tiara_y + 4)],
                    fill=color + (255,)
                )
            draw.arc([cx - 16, tiara_y, cx + 16, tiara_y + 10],
                     200, 340, fill=color + (255,), width=2)

        elif accessory == "tophat":
            hat_y = cy - head_r - 2
            # Brim
            draw.ellipse([cx - 22, hat_y + 2, cx + 22, hat_y + 10],
                         fill=color + (255,),
                         outline=ColorUtils.darken(color, 0.5) + (255,), width=1)
            # Tall top
            draw.rectangle([cx - 14, hat_y - 24, cx + 14, hat_y + 6],
                           fill=color + (255,),
                           outline=ColorUtils.darken(color, 0.5) + (255,), width=1)
            # Hat band
            draw.rectangle([cx - 14, hat_y - 4, cx + 14, hat_y + 1],
                           fill=ColorUtils.darken(color, 0.5) + (255,))

        elif accessory == "drum":
            # Small drum on the side of the body
            drum_x = cx + head_r + 2
