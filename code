class RacePhase(Enum):
    """Phases of a race."""
    COUNTDOWN = auto()
    RACING = auto()
    PHOTO_FINISH = auto()
    CELEBRATION = auto()
    FINISHED = auto()

@dataclass
class RaceState:
    """Complete state of the race at any point in time."""
    phase: RacePhase = RacePhase.COUNTDOWN
    frame_number: int = 0
    elapsed_time: float = 0.0
    total_frames: int = 0
    characters: List[Character] = field(default_factory=list)
    winner: Optional[Character] = None
    placements: List[Character] = field(default_factory=list)
    events_active: List[Any] = field(default_factory=list)
    camera_shake: Tuple[float, float] = (0.0, 0.0)
    camera_zoom: float = 1.0
    countdown_value: int = 3
    race_started: bool = False
    race_ended: bool = False
    celebration_timer: float = 0.0
    finish_line_reached: bool = False
    global_speed_modifier: float = 1.0

    # Timing
    countdown_start_frame: int = 0
    race_start_frame: int = 0
    race_end_frame: int = 0


class RaceSimulator:
    """
    Core race simulation engine.
    Handles physics, character movement, race progression,
    winner detection, and state management.
    """

    def __init__(self, config: MasterConfig, rng: random.Random):
        self.config = config
        self.rng = rng
        self.rc = config.race
        self.state = RaceState()

        # Pre-compute frame counts
        fps = config.video.fps
        countdown_frames = int(self.rc.countdown_duration * fps)
        race_frames = int(
            rng.uniform(self.rc.min_race_duration, self.rc.max_race_duration) * fps
        )
        celebration_frames = int(self.rc.winner_celebration_duration * fps)
        total = countdown_frames + race_frames + celebration_frames

        self.countdown_frames = countdown_frames
        self.race_frames = race_frames
        self.celebration_frames = celebration_frames
        self.state.total_frames = total
        self.dt = 1.0 / fps

        log.info(f"  Race simulation: {countdown_frames} countdown + "
                 f"{race_frames} race + {celebration_frames} celebration "
                 f"= {total} total frames ({total/fps:.1f}s)")

    def initialize(self, characters: List[Character]):
        """Set up the race with given characters."""
        self.state.characters = characters
        self.state.phase = RacePhase.COUNTDOWN
        self.state.frame_number = 0

        # Position characters at start
        for char in characters:
            char.position = 0.0
            char.velocity = 0.0
            char.current_speed = 0.0
            char.set_animation("idle")

        # Pre-compute target finish to ensure a close race
        self._compute_speed_profiles()

    def _compute_speed_profiles(self):
        """
        Pre-compute speed modifiers so the race is exciting and close.
        We want characters to be near each other for most of the race.
        """
        n = len(self.state.characters)
        # Assign random finish order
        finish_order = list(range(n))
        self.rng.shuffle(finish_order)

        # The winner finishes exactly at the race frame count
        # Others finish slightly later
        for char in self.state.characters:
            rank = finish_order[char.lane]
            # Speed factor: winner gets ~1.0, others get slightly less
            # but with variance so positions change during the race
            base_factor = 1.0 - rank * 0.015
            noise = self.rng.uniform(-0.008, 0.008)
            char._speed_factor = base_factor + noise
            char._surge_frame = self.rng.randint(
                self.race_frames // 3, self.race_frames - 10
            )
            char._surge_power = self.rng.uniform(0.3, 0.8) if rank < 2 else self.rng.uniform(0.1, 0.4)
            char.placement = rank + 1  # Will be recalculated

    def simulate_frame(self) -> RaceState:
        """Simulate one frame of the race. Call this each frame."""
        state = self.state
        frame = state.frame_number

        if state.phase == RacePhase.COUNTDOWN:
            self._update_countdown(frame)
        elif state.phase == RacePhase.RACING:
            self._update_racing(frame)
        elif state.phase == RacePhase.CELEBRATION:
            self._update_celebration(frame)

        state.frame_number += 1
        state.elapsed_time = state.frame_number * self.dt
        return state

    def _update_countdown(self, frame: int):
        """Update countdown phase."""
        state = self.state
        progress = frame / max(1, self.countdown_frames)

        # Countdown number (3, 2, 1, GO!)
        if progress < 0.25:
            state.countdown_value = 3
        elif progress < 0.50:
            state.countdown_value = 2
        elif progress < 0.75:
            state.countdown_value = 1
        else:
            state.countdown_value = 0  # GO!

        # Characters idle during countdown
        for char in state.characters:
            char.advance_animation(self.dt)

        # Transition to racing
        if frame >= self.countdown_frames:
            state.phase = RacePhase.RACING
            state.race_start_frame = frame
            state.race_started = True
            for char in state.characters:
                char.set_animation("run")
            log.info("  🟢 Race started!")

    def _update_racing(self, frame: int):
        """Update racing phase - move characters forward."""
        state = self.state
        race_frame = frame - self.countdown_frames
        race_progress = race_frame / max(1, self.race_frames)

        for char in state.characters:
            if char.finished:
                continue

            # Base speed from stats
            base = char.stats.base_speed * char._speed_factor

            # Add procedural noise for organic movement
            noise = MathUtils.noise_1d(
                race_frame * 0.05 + char.lane * 100, octaves=3
            ) * self.rc.speed_variance

            # Surge near the end for excitement
            surge = 0.0
            frames_since_surge = race_frame - char._surge_frame
            if 0 <= frames_since_surge < 30:
                surge_t = frames_since_surge / 30.0
                surge = char._surge_power * math.sin(surge_t * math.pi) * base

            # Random burst
            burst = 0.0
            if not char.is_boosting and self.rng.random() < char.stats.burst_chance:
                char.is_boosting = True
                char.boost_frames_left = self.rng.randint(8, 20)

            if char.is_boosting:
                burst = base * char.stats.burst_power * 0.3
                char.boost_frames_left -= 1
                if char.boost_frames_left <= 0:
                    char.is_boosting = False

            # Stamina effect
            stamina_factor = 0.7 + 0.3 * (char.stamina_current / char.stats.stamina)
            char.stamina_current = max(0.1,
                char.stamina_current - 0.001 + char.stats.recovery_rate * 0.0005)

            # Consistency: less consistent = more random variation
            consistency_noise = self.rng.gauss(0, (1 - char.stats.consistency) * 0.003)

            # Final speed calculation
            speed = (base + noise * 0.3 + surge + burst + consistency_noise) * stamina_factor
            speed *= state.global_speed_modifier
            speed = max(0.001, speed)

            # Update position
            char.velocity = speed
            char.current_speed = speed
            char.position += speed

            # Clamp
            char.position = MathUtils.clamp(char.position, 0.0, 1.2)

            # Record history
            char.position_history.append(char.position)
            char.speed_history.append(speed)

            # Check finish
            if char.position >= 1.0 and not char.finished:
                char.finished = True
                char.finish_time = state.elapsed_time
                state.placements.append(char)
                if state.winner is None:
                    state.winner = char
                    log.info(f"  🏆 WINNER: {char.name}! "
                             f"(time={char.finish_time:.2f}s)")

            # Advance animation
            char.advance_animation(self.dt, self.config.animation.animation_speed)

        # Check if race should end
        all_near_finish = all(c.position >= 0.85 for c in state.characters)
        if state.winner is not None and (race_frame >= self.race_frames or all_near_finish):
            state.phase = RacePhase.CELEBRATION
            state.race_end_frame = frame
            state.race_ended = True
            # Assign placements to those who didn't finish
            for char in state.characters:
                if char not in state.placements:
                    state.placements.append(char)
            for i, char in enumerate(state.placements):
                char.placement = i + 1
            # Switch winner to celebration
            if state.winner:
                state.winner.set_animation("celebrate")
            log.info("  🎉 Race ended! Moving to celebration.")

    def _update_celebration(self, frame: int):
        """Update celebration phase."""
        state = self.state
        celeb_frame = frame - state.race_end_frame
        state.celebration_timer = celeb_frame * self.dt

        # Animate winner
        if state.winner:
            state.winner.advance_animation(self.dt, 0.08)

        # Other characters idle
        for char in state.characters:
            if char != state.winner:
                char.set_animation("idle")
                char.advance_animation(self.dt)

        # End after celebration time
        if celeb_frame >= self.celebration_frames:
            state.phase = RacePhase.FINISHED

    def is_finished(self) -> bool:
        """Check if the entire race sequence is complete."""
        return self.state.phase == RacePhase.FINISHED

    def get_total_duration(self) -> float:
        """Get total race duration in seconds."""
        return self.state.total_frames / self.config.video.fps

