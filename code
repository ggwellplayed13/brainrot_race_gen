class RaceOrchestrator:
    """
    Master orchestrator that coordinates all systems to generate a complete race video.
    This is the main entry point for generating races.
    """

    def __init__(self, config: Optional[MasterConfig] = None):
        self.config = config or MasterConfig()
        FileUtils.ensure_dir(self.config.output_dir)

        # Initialize seed
        if self.config.seed is None:
            self.config.randomize_seed()
        self.rng = random.Random(self.config.seed)

        log.section("RACE ORCHESTRATOR INITIALIZED")
        log.info(f"  Seed: {self.config.seed}")
        log.info(f"  Output: {self.config.output_dir}")

    def generate_race(self, race_index: int = 0) -> str:
        """
        Generate a single complete race video.

        Returns:
            Path to the generated video file.
        """
        # Per-race seed for reproducibility
        race_seed = self.rng.randint(0, 2**32 - 1)
        race_rng = random.Random(race_seed)
        log.section(f"GENERATING RACE #{race_index + 1} (seed={race_seed})")

        # 1. Create characters
        log.info("📦 Creating characters...")
        char_factory = CharacterFactory(self.config)
        characters = char_factory.create_characters(
            self.config.race.num_characters, race_rng
        )
        gc.collect()   # free any temporary sprite-generation memory

        # 2. Create scene
        log.info("🎨 Creating scene...")
        scene = SceneFactory.random_scene(self.config, race_rng)

        # 3. Create race simulator
        log.info("🏎️ Initializing race simulation...")
        simulator = RaceSimulator(self.config, race_rng)
        simulator.initialize(characters)

        # 4. Create event engine
        log.info("⚡ Initializing event engine...")
        event_engine = RandomEventEngine(self.config, race_rng)

        # 5. Create frame renderer
        log.info("🖼️ Initializing frame renderer...")
        frame_renderer = FrameRenderer(self.config)

        # 6. Pre-simulate — store ONLY lightweight FrameSnapshot objects.
        # This avoids deep-copying Character objects (which carry PIL Image
        # sprite sheets) for every frame, which would use gigabytes of RAM.
        log.info("🔄 Pre-simulating race...")
        all_snapshots: List[FrameSnapshot] = []
        all_events: List[List[GameEvent]] = []

        sim_state = simulator.state
        total_frames = sim_state.total_frames

        def _snapshot_from_state(state: RaceState) -> FrameSnapshot:
            """Build a lightweight FrameSnapshot from the current RaceState."""
            chars = state.characters
            winner_idx = -1
            if state.winner is not None:
                try:
                    winner_idx = chars.index(state.winner)
                except ValueError:
                    winner_idx = -1
            return FrameSnapshot(
                phase=state.phase,
                frame_number=state.frame_number,
                elapsed_time=state.elapsed_time,
                total_frames=state.total_frames,
                countdown_value=state.countdown_value,
                camera_shake=state.camera_shake,
                camera_zoom=state.camera_zoom,
                celebration_timer=state.celebration_timer,
                winner_index=winner_idx,
                race_started=state.race_started,
                race_ended=state.race_ended,
                finish_line_reached=state.finish_line_reached,
                global_speed_modifier=state.global_speed_modifier,
                race_start_frame=state.race_start_frame,
                race_end_frame=state.race_end_frame,
                char_positions=[c.position for c in chars],
                char_velocities=[c.velocity for c in chars],
                char_speeds=[c.current_speed for c in chars],
                char_animations=[c.current_animation for c in chars],
                char_anim_frames=[c.animation_frame for c in chars],
                char_anim_timers=[c.animation_timer for c in chars],
                char_is_boosting=[c.is_boosting for c in chars],
                char_boost_frames_left=[c.boost_frames_left for c in chars],
                char_finished=[c.finished for c in chars],
                char_placements=[c.placement for c in chars],
                char_stamina=[c.stamina_current for c in chars],
                char_finish_times=[c.finish_time for c in chars],
            )

        for frame_idx in range(total_frames):
            state = simulator.simulate_frame()
            events = event_engine.update(state)
            all_snapshots.append(_snapshot_from_state(state))
            all_events.append(list(events))

            if simulator.is_finished():
                # Pad remaining frames with the final snapshot (very cheap)
                final_snap = _snapshot_from_state(state)
                for _ in range(frame_idx + 1, total_frames):
                    all_snapshots.append(final_snap)
                    all_events.append([])
                break

        actual_frames = len(all_snapshots)
        duration = actual_frames / self.config.video.fps
        log.info(f"  Simulation complete: {actual_frames} frames, {duration:.1f}s")
        gc.collect()   # free any residual simulation memory

        # 7. Generate audio
        log.info("🔊 Generating audio...")
        audio_manager = AudioManager(self.config)
        winner_name = simulator.state.winner.name if simulator.state.winner else "Unknown"
        audio_path = audio_manager.generate_race_audio(
            duration, winner_name,
            self.config.race.countdown_duration,
            duration - self.config.race.countdown_duration - self.config.race.winner_celebration_duration,
        )

        # 8. Create frame generator for video encoding
        log.info("🎬 Preparing video encoding...")

        # Small frame cache — large values waste RAM (each 720p frame ~2.5 MB)
        frame_cache: Dict[int, np.ndarray] = {}
        cache_limit = self.config.frame_cache_size

        def _apply_snapshot(snap: FrameSnapshot) -> None:
            """Write a FrameSnapshot's per-character data back to the
            shared Character objects so the renderer sees the right state."""
            for i, char in enumerate(characters):
                char.position          = snap.char_positions[i]
                char.velocity          = snap.char_velocities[i]
                char.current_speed     = snap.char_speeds[i]
                char.current_animation = snap.char_animations[i]
                char.animation_frame   = snap.char_anim_frames[i]
                char.animation_timer   = snap.char_anim_timers[i]
                char.is_boosting       = snap.char_is_boosting[i]
                char.boost_frames_left = snap.char_boost_frames_left[i]
                char.finished          = snap.char_finished[i]
                char.placement         = snap.char_placements[i]
                char.stamina_current   = snap.char_stamina[i]
                char.finish_time       = snap.char_finish_times[i]

        def make_frame(t: float) -> np.ndarray:
            """Generate frame for time t."""
            frame_idx = int(t * self.config.video.fps)
            frame_idx = min(frame_idx, actual_frames - 1)

            if frame_idx in frame_cache:
                return frame_cache[frame_idx]

            snap = all_snapshots[frame_idx]
            events = all_events[frame_idx]

            # Restore character state for this frame (no deepcopy needed)
            _apply_snapshot(snap)

            # Build a minimal RaceState for the renderer (no Character copying)
            render_state = RaceState(
                phase=snap.phase,
                frame_number=snap.frame_number,
                elapsed_time=snap.elapsed_time,
                total_frames=snap.total_frames,
                countdown_value=snap.countdown_value,
                camera_shake=snap.camera_shake,
                camera_zoom=snap.camera_zoom,
                celebration_timer=snap.celebration_timer,
                race_started=snap.race_started,
                race_ended=snap.race_ended,
                finish_line_reached=snap.finish_line_reached,
                global_speed_modifier=snap.global_speed_modifier,
                race_start_frame=snap.race_start_frame,
                race_end_frame=snap.race_end_frame,
                characters=characters,
                winner=characters[snap.winner_index] if snap.winner_index >= 0 else None,
                placements=[c for c in characters if c.finished],
            )

            rendered = frame_renderer.render_frame(
                scene, render_state, events, frame_idx
            )

            # Cache last N frames only (each frame: ~2.5 MB at 720p, ~6 MB at 1080p)
            frame_cache[frame_idx] = rendered
            if len(frame_cache) > cache_limit:
                oldest = min(frame_cache.keys())
                del frame_cache[oldest]

            # Periodic GC to prevent frame buffer accumulation
            if frame_idx % 100 == 0 and frame_idx > 0:
                gc.collect()

            return rendered

        # 9. Encode video
        output_filename = FileUtils.unique_filename(
            prefix=f"race_{race_index:03d}", ext=".mp4"
        )
        output_path = os.path.join(self.config.output_dir, output_filename)

        encoder = VideoEncoder(self.config)
        result_path = encoder.encode_video(
            frame_generator=make_frame,
            duration=duration,
            audio_path=audio_path,
            output_path=output_path,
        )

        # 10. Cleanup
        audio_manager.cleanup()
        frame_cache.clear()
        gc.collect()   # final cleanup after encoding

        log.info(f"  🏁 Race #{race_index + 1} complete!")
        log.info(f"     Winner: {winner_name}")
        log.info(f"     File: {result_path}")

        return result_path

    def generate_batch(self, count: Optional[int] = None) -> List[str]:
        """
        Generate multiple race videos in batch.

        Args:
            count: Number of races to generate (uses config.batch_size if None).

        Returns:
            List of paths to generated video files.
        """
        num_races = count or self.config.batch_size
        log.section(f"BATCH GENERATION: {num_races} RACES")

        results = []
        for i in range(num_races):
            try:
                path = self.generate_race(i)
                results.append(path)
            except Exception as e:
                log.error(f"  ❌ Race #{i + 1} failed: {e}")
                traceback.print_exc()
                continue

        log.section("BATCH COMPLETE")
        log.info(f"  Generated {len(results)}/{num_races} videos successfully.")
        for path in results:
            log.info(f"    📹 {path}")

        return results

