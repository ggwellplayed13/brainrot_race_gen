class FrameRenderer:
    """
    Composites all visual elements into a single frame.
    Combines: background, characters, events, HUD, overlays.
    """

    def __init__(self, config: MasterConfig):
        self.config = config
        self.vc = config.video
        self.ac = config.animation
        self.hud = HUDRenderer(config)
        self.event_renderer = EventRenderer(config)
        self._who_will_win_frame: int = -1
        self._race_start_frame: int = -1

    def render_frame(
        self,
        scene: BaseScene,
        state: RaceState,
        events: List[GameEvent],
        frame: int,
    ) -> np.ndarray:
        """
        Render a complete frame as a numpy array (H, W, 3) uint8 RGB.
        """
        w, h = self.vc.width, self.vc.height
        race_progress = state.elapsed_time / max(0.01, state.total_frames / self.vc.fps)

        # 1. Render background
        bg = scene.render_background(frame, race_progress)

        # 2. Render characters onto background
        img = self._render_characters(bg, state, scene, frame)

        # 3. Render events
        img = self.event_renderer.render_events(img, events, frame)

        # 4. Render HUD based on phase
        if state.phase == RacePhase.COUNTDOWN:
            countdown_progress = frame / max(1, state.total_frames * 0.15)
            img = self.hud.render_countdown(img, state.countdown_value, countdown_progress)
            self._race_start_frame = -1
            self._who_will_win_frame = -1
        elif state.phase == RacePhase.RACING:
            # Track when the race started for GO! GO! GO! callout
            if self._race_start_frame < 0:
                self._race_start_frame = frame
            race_local = frame - self._race_start_frame

            img = self.hud.render_race_hud(img, state.characters, frame)
            img = self.hud.render_name_tags(img, state.characters, scene)
            if self.config.scene.subscribe_watermark:
                img = self.hud.render_subscribe_watermark(img, frame)
            img = self.hud.render_progress_bar(img, state.characters)

            # GO! GO! GO! — first ~1s of race
            img = self.hud.render_go_callout(img, race_local)

            # WHO WILL WIN?! — at 65-75% progress, trigger once
            if self.config.effects.who_will_win_text:
                if 0.65 <= race_progress <= 0.85:
                    if self._who_will_win_frame < 0:
                        self._who_will_win_frame = frame
                    img = self.hud.render_who_will_win(img, frame, self._who_will_win_frame)

            # PHOTO FINISH! — top 2 within 0.03 when leader is past 0.85
            if state.characters:
                sorted_by_pos = sorted(state.characters, key=lambda c: c.position, reverse=True)
                if (len(sorted_by_pos) >= 2 and
                        sorted_by_pos[0].position >= 0.85 and
                        abs(sorted_by_pos[0].position - sorted_by_pos[1].position) <= 0.03):
                    img = self.hud.render_photo_finish(img, frame)

            # Overtake callout: show when a character gets a speed boost
            if self.config.effects.overtake_callout:
                for ev in events:
                    if ev.event_type == EventType.SPEED_BOOST and ev.age < 10:
                        char_name = ev.data.get("target_name", "")
                        img = self.hud.render_overtake_callout(img, char_name, int(ev.age))
                        break
        elif state.phase == RacePhase.CELEBRATION:
            img = self.hud.render_race_hud(img, state.characters, frame)
            if state.winner:
                celeb_progress = state.celebration_timer / \
                    self.config.race.winner_celebration_duration
                img = self.hud.render_winner_announcement(
                    img, state.winner, celeb_progress
                )

        # 5. Apply camera shake
        shake_x, shake_y = state.camera_shake
        if abs(shake_x) > 0.5 or abs(shake_y) > 0.5:
            img = self._apply_camera_shake(img, shake_x, shake_y)

        # 5b. Screen border glow during exciting moments
        if self.config.effects.screen_border_glow and state.phase == RacePhase.RACING:
            img = self._render_border_glow(img, frame, race_progress)

        # 6. Convert to numpy RGB array
        # Ensure RGBA then convert to RGB
        if img.mode != "RGBA":
            img = img.convert("RGBA")

        # Flatten onto black background
        flat = Image.new("RGB", (w, h), (0, 0, 0))
        flat.paste(img, (0, 0), img)

        return np.array(flat, dtype=np.uint8)

    def _render_characters(
        self, bg: Image.Image, state: RaceState,
        scene: BaseScene, frame: int
    ) -> Image.Image:
        """Render all characters onto the background."""
        img = bg.copy()
        total_lanes = self.config.race.lane_count

        # Sort by lane for proper layering (back lanes first)
        sorted_chars = sorted(state.characters, key=lambda c: c.lane)

        for char in sorted_chars:
            # Calculate screen position
            screen_x = scene.get_character_x(char.position)
            screen_y = scene.get_lane_y(char.lane, total_lanes)

            # Get sprite
            sprite = char.get_current_sprite()
            if sprite is None:
                continue

            # Apply bounce for running
            bounce_y = 0
            if char.current_animation == "run":
                bounce_y = int(
                    math.sin(frame * 0.4 + char.lane) * self.ac.bounce_amplitude
                )
            elif char.current_animation == "celebrate":
                bounce_y = int(
                    abs(math.sin(frame * 0.3)) * self.ac.celebration_jump_height
                )

            # Store screen position for HUD
            char.screen_x = screen_x
            char.screen_y = screen_y + bounce_y

            # Scale sprite (perspective: back lanes slightly smaller)
            scale_factor = 0.85 + 0.15 * (char.lane / max(1, total_lanes - 1))
            # Speed squash/stretch
            if char.is_boosting:
                scale_factor *= 1.05  # Slightly wider when boosting

            new_w = int(self.ac.sprite_width * scale_factor)
            new_h = int(self.ac.sprite_height * scale_factor)
            if new_w > 0 and new_h > 0:
                scaled_sprite = sprite.resize((new_w, new_h), Image.LANCZOS)
            else:
                continue

            # Position (center sprite on screen position)
            paste_x = screen_x - new_w // 2
            paste_y = screen_y + bounce_y - new_h // 2

            # Draw shadow
            shadow = Image.new("RGBA", (new_w, new_h // 4), (0, 0, 0, 0))
            shadow_draw = ImageDraw.Draw(shadow)
            shadow_draw.ellipse(
                [new_w // 4, 0, new_w * 3 // 4, new_h // 4],
                fill=(0, 0, 0, 60)
            )
            shadow_y = screen_y + new_h // 3
            try:
                img.paste(shadow, (paste_x + new_w // 8, shadow_y), shadow)
            except (ValueError, Exception):
                pass

            # Speed trails / afterimages when boosting
            if char.is_boosting and self.config.effects.speed_trails:
                trail_count = self.config.animation.speed_trail_count
                for trail_i in range(trail_count):
                    trail_offset = (trail_i + 1) * 20
                    trail_alpha = max(10, 80 - trail_i * (70 // max(1, trail_count)))
                    trail_sprite = scaled_sprite.copy()
                    trail_arr = np.array(trail_sprite)
                    trail_arr[:, :, 3] = (trail_arr[:, :, 3] * trail_alpha // 255).astype(np.uint8)
                    trail_img = Image.fromarray(trail_arr, 'RGBA')
                    try:
                        img.paste(trail_img, (paste_x - trail_offset, paste_y), trail_img)
                    except Exception:
                        pass

            # Paste character sprite
            try:
                img.paste(scaled_sprite, (paste_x, paste_y), scaled_sprite)
            except (ValueError, Exception):
                # Fallback: try without alpha
                try:
                    img.paste(scaled_sprite, (paste_x, paste_y))
                except Exception:
                    pass

            # Boost effect glow
            if char.is_boosting:
                glow = Image.new("RGBA", (new_w + 20, new_h + 20), (0, 0, 0, 0))
                glow_draw = ImageDraw.Draw(glow)
                body_color = char.template.get("body_color", (255, 200, 0))
                glow_alpha = int(abs(math.sin(frame * 0.5)) * 80) + 30
                glow_draw.ellipse(
                    [0, 0, new_w + 20, new_h + 20],
                    fill=body_color + (glow_alpha,)
                )
                glow = glow.filter(ImageFilter.GaussianBlur(radius=8))
                try:
                    img.paste(glow, (paste_x - 10, paste_y - 10), glow)
                except Exception:
                    pass

        return img

    def _apply_camera_shake(
        self, img: Image.Image, shake_x: float, shake_y: float
    ) -> Image.Image:
        """Apply camera shake by shifting the image."""
        sx = int(shake_x)
        sy = int(shake_y)
        if sx == 0 and sy == 0:
            return img
        shifted = Image.new("RGBA", img.size, (0, 0, 0, 255))
        shifted.paste(img, (sx, sy))
        return shifted

    def _render_border_glow(
        self, img: Image.Image, frame: int, race_progress: float
    ) -> Image.Image:
        """Render a pulsing colored border glow around the screen."""
        if race_progress < 0.5:
            return img
        w, h = img.size
        # Intensity increases near finish
        intensity = min(1.0, (race_progress - 0.5) * 2.0)
        hue = (frame * 0.02) % 1.0
        rc, gc, bc = [int(c * 255) for c in colorsys.hsv_to_rgb(hue, 1.0, 1.0)]
        glow_alpha = int(intensity * 60 * abs(math.sin(frame * 0.1)))
        if glow_alpha < 5:
            return img
        overlay = Image.new("RGBA", img.size, (0, 0, 0, 0))
        ov_draw = ImageDraw.Draw(overlay)
        border = 20
        # Draw thick border
        for b in range(border, 0, -4):
            a = int(glow_alpha * b / border)
            ov_draw.rectangle([border - b, border - b, w - (border - b), h - (border - b)],
                             outline=(rc, gc, bc, a), width=4)
        return Image.alpha_composite(img, overlay)


