class VideoEncoder:
    """
    Encodes rendered frames into a video file using MoviePy.
    Supports audio mixing and various output formats.
    """

    def __init__(self, config: MasterConfig):
        self.config = config
        self.vc = config.video

    def encode_video(
        self,
        frame_generator: Callable[[float], np.ndarray],
        duration: float,
        audio_path: Optional[str],
        output_path: str,
    ) -> str:
        """
        Encode video from a frame generator function.

        Args:
            frame_generator: Function that takes time (seconds) and returns
                             numpy array (H, W, 3) uint8.
            duration: Total video duration in seconds.
            audio_path: Path to audio file (or None).
            output_path: Output video file path.

        Returns:
            Path to the encoded video file.
        """
        log.info(f"  🎬 Encoding video: {duration:.1f}s @ {self.vc.fps}fps")
        log.info(f"     Resolution: {self.vc.width}x{self.vc.height}")
        log.info(f"     Output: {output_path}")

        # Create video clip from frame generator
        video_clip = VideoClip(
            lambda t: frame_generator(t),
            duration=duration,
        ).set_fps(self.vc.fps)

        # Add audio if available
        if audio_path and os.path.exists(audio_path):
            try:
                audio_clip = AudioFileClip(audio_path)
                # Trim audio to video duration
                if audio_clip.duration > duration:
                    audio_clip = audio_clip.subclip(0, duration)
                video_clip = video_clip.set_audio(audio_clip)
                log.info("     Audio attached successfully.")
            except Exception as e:
                log.warning(f"     Could not attach audio: {e}")

        # Write video file
        video_clip.write_videofile(
            output_path,
            fps=self.vc.fps,
            codec=self.vc.codec,
            bitrate=self.vc.bitrate,
            audio_codec=self.vc.audio_codec if audio_path else None,
            logger=None,  # Suppress moviepy progress bar noise
            threads=4,
        )

        # Clean up
        video_clip.close()

        file_size_mb = os.path.getsize(output_path) / (1024 * 1024)
        log.info(f"  ✅ Video saved: {output_path} ({file_size_mb:.1f} MB)")

        return output_path

