class EventRenderer:
    """Renders visual effects for random events."""

    def __init__(self, config: MasterConfig):
        self.config = config

    def render_events(
        self, img: Image.Image, events: List[GameEvent], frame: int
    ) -> Image.Image:
        """Render all active events onto the frame."""
        for event in events:
            if event.event_type == EventType.BIRD_FLOCK:
                img = self._render_birds(img, event)
            elif event.event_type == EventType.CONFETTI_BURST:
                img = self._render_confetti(img, event)
            elif event.event_type == EventType.LIGHTNING_FLASH:
                img = self._render_lightning(img, event)
            elif event.event_type == EventType.SPEED_LINES:
                img = self._render_speed_lines(img, event)
            elif event.event_type == EventType.DUST_CLOUD:
                img = self._render_dust(img, event)
        return img

    def _render_birds(self, img: Image.Image, event: GameEvent) -> Image.Image:
        """Render flying bird silhouettes."""
        draw = ImageDraw.Draw(img)
        for bird in event.data.get("birds", []):
            bx = int(bird["x"])
            by = int(bird["y"])
            wing = math.sin(bird["wing_phase"]) * bird["size"]
            # Bird V-shape
            draw.line([bx - bird["size"], by + int(wing),
                       bx, by], fill=(20, 20, 30, 200), width=2)
            draw.line([bx, by,
                       bx + bird["size"], by + int(wing)],
                      fill=(20, 20, 30, 200), width=2)
        return img

    def _render_confetti(self, img: Image.Image, event: GameEvent) -> Image.Image:
        """Render confetti particles."""
        draw = ImageDraw.Draw(img)
        for p in event.data.get("particles", []):
            px = int(p["x"])
            py = int(p["y"])
            size = p["size"]
            color = p["color"]
            alpha = max(0, int(200 * (1 - event.progress)))
            draw.rectangle([px, py, px + size, py + size // 2],
                           fill=color + (alpha,))
        return img

    def _render_lightning(self, img: Image.Image, event: GameEvent) -> Image.Image:
        """Render lightning flash."""
        intensity = event.data["intensity"]
        progress = event.progress
        flash_alpha = int(intensity * (1 - progress) * 200)
        if flash_alpha > 0:
            overlay = Image.new("RGBA", img.size, (255, 255, 255, flash_alpha))
            img = Image.alpha_composite(img, overlay)
        return img

    def _render_speed_lines(self, img: Image.Image, event: GameEvent) -> Image.Image:
        """Render speed lines."""
        draw = ImageDraw.Draw(img)
        alpha = int(200 * (1 - event.progress))
        for line in event.data.get("lines", []):
            lx = int(line["x"])
            ly = int(line["y"])
            length = line["length"]
            draw.line([lx, ly, lx + length, ly],
                      fill=(255, 255, 255, min(alpha, line["alpha"])),
                      width=line["thickness"])
        return img

    def _render_dust(self, img: Image.Image, event: GameEvent) -> Image.Image:
        """Render dust cloud particles."""
        draw = ImageDraw.Draw(img)
        for p in event.data.get("particles", []):
            px = int(p["x"])
            py = int(p["y"])
            size = int(p["size"])
            alpha = int(p["alpha"])
            if alpha > 0 and size > 0:
                draw.ellipse([px - size, py - size, px + size, py + size],
                             fill=(180, 160, 130, alpha))
        return img

