class AudioManager:
    """
    Manages audio generation for the race video.
    Generates:
    - Background race music (procedural)
    - Countdown beeps
    - Winner TTS announcement
    """

    def __init__(self, config: MasterConfig):
        self.config = config
        self.temp_dir = FileUtils.ensure_dir(os.path.join(config.output_dir, "temp_audio"))

    def generate_countdown_beep(self, frequency: float = 800, duration_ms: int = 200) -> np.ndarray:
        """Generate a musical beep sound (chord) as numpy array."""
        sample_rate = 44100
        n = int(sample_rate * duration_ms / 1000.0)
        t = np.linspace(0, duration_ms / 1000.0, n, dtype=np.float64)
        # Major chord: root + major third
        third = frequency * 1.25  # approx major third
        wave = (np.sin(2 * np.pi * frequency * t) * 0.4 +
                np.sin(2 * np.pi * third * t) * 0.3)
        fade = int(n * 0.1)
        env = np.ones(n, dtype=np.float64)
        if fade > 0:
            env[:fade] = np.linspace(0.0, 1.0, fade)
            env[-fade:] = np.linspace(1.0, 0.0, fade)
        return (wave * env * 32767).astype(np.int16)

    def generate_race_audio(
        self, total_duration: float, winner_name: str,
        countdown_duration: float, race_duration: float
    ) -> Optional[str]:
        """
        Generate complete race audio track.
        Returns path to audio file.
        """
        sample_rate = 44100
        total_samples = int(total_duration * sample_rate)
        audio = np.zeros(total_samples, dtype=np.float64)
        rng_audio = np.random.default_rng(1234)

        # --- Countdown beeps — musical major chord beeps ---
        # Beeps at 0, 1, 2 seconds; GO! at countdown end
        beep_times = [0.0, 1.0, 2.0, countdown_duration - 0.15]
        beep_freqs = [261, 261, 261, 523]   # C4, C4, C4, C5
        beep_thirds = [329, 329, 329, 659]  # E4, E4, E4, E5
        beep_fifths = [None, None, None, 784]  # G5 only on GO!
        beep_durations = [150, 150, 150, 300]

        for bt, bf, bth, bfi, bd in zip(beep_times, beep_freqs, beep_thirds, beep_fifths, beep_durations):
            n = int(sample_rate * bd / 1000.0)
            t_b = np.linspace(0, bd / 1000.0, n, dtype=np.float64)
            fade = max(1, int(n * 0.1))
            env = np.ones(n, dtype=np.float64)
            env[:fade] = np.linspace(0.0, 1.0, fade)
            env[-fade:] = np.linspace(1.0, 0.0, fade)
            wave_b = (np.sin(2 * np.pi * bf * t_b) * 0.35 +
                      np.sin(2 * np.pi * bth * t_b) * 0.25)
            if bfi is not None:
                wave_b += np.sin(2 * np.pi * bfi * t_b) * 0.20
            wave_b *= env
            start_s = int(bt * sample_rate)
            end_s = min(start_s + n, total_samples)
            actual = end_s - start_s
            if actual > 0:
                audio[start_s:end_s] += wave_b[:actual] * 0.55

        # --- Background rhythm during race ---
        race_start_sample = int(countdown_duration * sample_rate)
        race_end_sample = int((countdown_duration + race_duration) * sample_rate)
        race_end_sample = min(race_end_sample, total_samples)
        race_len = race_end_sample - race_start_sample
        if race_len <= 0:
            race_len = 1

        bpm = 150
        beat_interval = 60.0 / bpm
        beat_samples = int(beat_interval * sample_rate)
        half_beat = beat_samples // 2
        num_beats = int(race_duration / beat_interval) + 1

        # Kick drum — punchy 60Hz with fast decay
        kick_len = int(0.12 * sample_rate)
        kick_t = np.arange(kick_len, dtype=np.float64) / sample_rate
        kick_base = np.sin(2 * np.pi * 60 * kick_t) * np.exp(-kick_t * 30) * 0.35

        # Snare/clap — bandpass-feel noise burst on beats 2 and 4
        snare_len = int(0.06 * sample_rate)
        snare_t = np.arange(snare_len, dtype=np.float64) / sample_rate
        snare_noise = rng_audio.standard_normal(snare_len)
        snare_env = np.exp(-snare_t * 40) * np.abs(np.sin(2 * np.pi * 180 * snare_t))
        snare_base = snare_noise * snare_env * 0.18

        # Hi-hat
        hh_len = int(0.025 * sample_rate)
        hh_t = np.arange(hh_len, dtype=np.float64) / sample_rate
        hh_noise = rng_audio.standard_normal(hh_len)
        hh_env = np.exp(-hh_t * 80)
        hh_base = hh_noise * hh_env * 0.04

        for i in range(num_beats):
            beat_pos = i * beat_samples
            # Kick on every beat
            k_start = race_start_sample + beat_pos
            k_end = min(k_start + kick_len, race_end_sample)
            actual = k_end - k_start
            if actual > 0 and k_start < total_samples:
                audio[k_start:k_end] += kick_base[:actual]
            # Snare on beats 2 and 4 (index 1, 3 within 4-beat pattern)
            beat_in_bar = i % 4
            if beat_in_bar in (1, 3):
                s_start = race_start_sample + beat_pos
                s_end = min(s_start + snare_len, race_end_sample)
                actual = s_end - s_start
                if actual > 0 and s_start < total_samples:
                    audio[s_start:s_end] += snare_base[:actual]
            # Hi-hat on every half-beat
            for hh_off in (0, half_beat):
                hh_start = race_start_sample + beat_pos + hh_off
                hh_end = min(hh_start + hh_len, race_end_sample)
                actual = hh_end - hh_start
                if actual > 0 and hh_start < total_samples:
                    audio[hh_start:hh_end] += hh_base[:actual]

        # Bass line — C3, E3, G3, C3 repeating every 4 beats
        bass_notes = [131.0, 165.0, 196.0, 131.0]  # C3, E3, G3, C3
        note_dur = int(beat_samples * 0.8)  # slightly shorter than a beat for punch
        note_t = np.arange(note_dur, dtype=np.float64) / sample_rate
        note_env = np.exp(-note_t * 6)
        for i in range(num_beats):
            note_freq = bass_notes[i % 4]
            bass_wave = np.sin(2 * np.pi * note_freq * note_t) * note_env * 0.12
            b_start = race_start_sample + i * beat_samples
            b_end = min(b_start + note_dur, race_end_sample)
            actual = b_end - b_start
            if actual > 0 and b_start < total_samples:
                audio[b_start:b_end] += bass_wave[:actual]

        # Melody synth — bright sine + harmonic overtone
        # 8-note pattern: C5 E5 G5 E5 C5 D5 E5 C5
        melody_notes = [523.25, 659.25, 784.0, 659.25, 523.25, 587.33, 659.25, 523.25]
        mel_note_dur = half_beat
        mel_t = np.arange(mel_note_dur, dtype=np.float64) / sample_rate
        mel_fade = max(1, mel_note_dur // 8)
        mel_env = np.ones(mel_note_dur, dtype=np.float64)
        mel_env[:mel_fade] = np.linspace(0.0, 1.0, mel_fade)
        mel_env[-mel_fade:] = np.linspace(1.0, 0.0, mel_fade)
        mel_env *= np.exp(-mel_t * 4)
        melody_idx = 0
        for i in range(num_beats * 2):
            note_freq = melody_notes[melody_idx % len(melody_notes)]
            # bright wave: fundamental + 3rd harmonic at 0.3
            mel_wave = (np.sin(2 * np.pi * note_freq * mel_t) +
                        np.sin(2 * np.pi * note_freq * 3 * mel_t) * 0.3) * mel_env * 0.06
            m_start = race_start_sample + i * half_beat
            m_end = min(m_start + mel_note_dur, race_end_sample)
            actual = m_end - m_start
            if actual > 0 and m_start < total_samples:
                audio[m_start:m_end] += mel_wave[:actual]
            melody_idx += 1

        # Rising tension — last 25% of race: slowly rising sweep 200→800 Hz
        tension_start_frac = 0.75
        tension_start_s = race_start_sample + int(race_len * tension_start_frac)
        tension_end_s = race_end_sample
        ten_len = tension_end_s - tension_start_s
        if ten_len > 0:
            ten_t = np.arange(ten_len, dtype=np.float64) / sample_rate
            progress = np.linspace(0.0, 1.0, ten_len)
            freq_sweep = 200.0 + progress * 600.0
            phase_sweep = np.cumsum(freq_sweep / sample_rate) * 2 * np.pi
            tension_wave = np.sin(phase_sweep) * progress * 0.04
            audio[tension_start_s:tension_end_s] += tension_wave

        # --- Winner celebration sound ---
        celeb_start = race_end_sample
        celeb_len = total_samples - celeb_start
        if celeb_len > 0:
            celeb_t = np.arange(celeb_len, dtype=np.float64) / sample_rate
            # C major 7th: C4+E4+G4+B4
            victory_chord = (
                np.sin(2 * np.pi * 261.63 * celeb_t) * 0.18 +
                np.sin(2 * np.pi * 329.63 * celeb_t) * 0.15 +
                np.sin(2 * np.pi * 392.00 * celeb_t) * 0.13 +
                np.sin(2 * np.pi * 493.88 * celeb_t) * 0.10
            )
            chord_env = np.exp(-celeb_t * 0.6)  # slow decay over ~2.5s
            audio[celeb_start:total_samples] += victory_chord * chord_env

            # Sparkle sounds: 3 short high-pitched descending tones
            sparkle_starts = [0.05, 0.25, 0.55]
            sparkle_freqs = [(1200, 800), (1000, 600), (1100, 700)]
            spark_dur = int(0.18 * sample_rate)
            for sp_t_off, (sp_f1, sp_f2) in zip(sparkle_starts, sparkle_freqs):
                sp_start = celeb_start + int(sp_t_off * sample_rate)
                sp_end = min(sp_start + spark_dur, total_samples)
                sp_actual = sp_end - sp_start
                if sp_actual > 0:
                    sp_t = np.arange(sp_actual, dtype=np.float64) / sample_rate
                    sp_prog = np.linspace(0.0, 1.0, sp_actual)
                    sp_freq = sp_f1 - sp_prog * (sp_f1 - sp_f2)
                    sp_phase = np.cumsum(sp_freq / sample_rate) * 2 * np.pi
                    sp_env = np.exp(-sp_t * 12)
                    audio[sp_start:sp_end] += np.sin(sp_phase) * sp_env * 0.12

            # Crowd cheer: broadband noise with envelope
            cheer_len = min(celeb_len, int(1.5 * sample_rate))
            cheer_noise = rng_audio.standard_normal(cheer_len)
            cheer_t = np.arange(cheer_len, dtype=np.float64) / sample_rate
            attack = int(0.08 * sample_rate)
            cheer_env = np.exp(-cheer_t * 1.2)
            cheer_env[:attack] = np.linspace(0.0, 1.0, attack)
            audio[celeb_start:celeb_start + cheer_len] += cheer_noise * cheer_env * 0.06

            # Reverb-like effect: mix delayed copy at 30ms / 0.3 amplitude
            delay_samples = int(0.030 * sample_rate)
            reverb_start = celeb_start + delay_samples
            reverb_end = min(reverb_start + celeb_len, total_samples)
            reverb_src_end = reverb_end - reverb_start + celeb_start
            if reverb_end > reverb_start and reverb_src_end <= total_samples:
                audio[reverb_start:reverb_end] += (
                    audio[celeb_start:reverb_src_end] * 0.3
                )

        # --- Winner TTS ---
        tts_path = self._generate_tts(winner_name)
        if tts_path and os.path.exists(tts_path):
            try:
                tts_audio_seg = AudioSegment.from_file(tts_path)
                tts_samples = np.array(tts_audio_seg.get_array_of_samples(), dtype=np.float64)
                if tts_audio_seg.channels == 2:
                    tts_samples = tts_samples[::2]
                tts_samples = tts_samples / 32768.0 * 0.8

                if tts_audio_seg.frame_rate != sample_rate:
                    ratio = sample_rate / tts_audio_seg.frame_rate
                    new_len = int(len(tts_samples) * ratio)
                    tts_samples = np.interp(
                        np.linspace(0, len(tts_samples) - 1, new_len),
                        np.arange(len(tts_samples)),
                        tts_samples,
                    )

                tts_start = celeb_start + int(0.8 * sample_rate)
                tts_end = min(tts_start + len(tts_samples), total_samples)
                actual_len = tts_end - tts_start
                if actual_len > 0:
                    audio[tts_start:tts_end] += tts_samples[:actual_len]
            except Exception as e:
                log.warning(f"Could not load TTS audio: {e}")

        # Normalize to 0.80 peak
        max_val = np.max(np.abs(audio))
        if max_val > 0:
            audio = audio / max_val * 0.80

        # Convert to int16
        audio_int16 = (audio * 32767).astype(np.int16)

        # Save to WAV
        audio_path = os.path.join(self.temp_dir, "race_audio.wav")
        import wave as wave_mod
        with wave_mod.open(audio_path, 'w') as wav_file:
            wav_file.setnchannels(1)
            wav_file.setsampwidth(2)
            wav_file.setframerate(sample_rate)
            wav_file.writeframes(audio_int16.tobytes())

        log.info(f"  🔊 Audio generated: {audio_path}")
        return audio_path

    def _generate_tts(self, text: str) -> Optional[str]:
        """Generate TTS audio for winner announcement."""
        try:
            tts_text = f"{text} wins the race!"
            tts = gTTS(text=tts_text, lang='en', slow=False)
            tts_path = os.path.join(self.temp_dir, "winner_tts.mp3")
            tts.save(tts_path)
            return tts_path
        except Exception as e:
            log.warning(f"TTS generation failed: {e}")
            return None

    def cleanup(self):
        """Clean up temporary audio files."""
        FileUtils.cleanup_temp_files(self.temp_dir, "*.wav")
        FileUtils.cleanup_temp_files(self.temp_dir, "*.mp3")

print("✅ Audio system loaded.")

