def display_video_in_colab(video_path: str):
    """Display a video inline in Google Colab."""
    try:
        from IPython.display import HTML, display
        import base64

        if not os.path.exists(video_path):
            print(f"❌ Video not found: {video_path}")
            return

        file_size_mb = os.path.getsize(video_path) / (1024 * 1024)

        if file_size_mb > 50:
            print(f"⚠️ Video too large to display inline ({file_size_mb:.1f}MB).")
            print(f"   Download from: {video_path}")
            return

        with open(video_path, 'rb') as f:
            video_data = f.read()

        video_b64 = base64.b64encode(video_data).decode('utf-8')

        html = f"""
        <div style="text-align: center; margin: 20px 0;">
            <h3>🏁 Generated Race Video</h3>
            <video width="360" height="640" controls autoplay loop
                   style="border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
                <source src="data:video/mp4;base64,{video_b64}" type="video/mp4">
                Your browser does not support the video tag.
            </video>
            <p style="color: #888; margin-top: 8px;">
                📁 {os.path.basename(video_path)} ({file_size_mb:.1f} MB)
            </p>
        </div>
        """
        display(HTML(html))
        print(f"✅ Video displayed. File: {video_path}")

    except ImportError:
        print(f"📁 Video saved to: {video_path}")
        print("   (Install IPython to display inline)")
    except Exception as e:
        print(f"⚠️ Could not display video inline: {e}")
        print(f"   Video saved to: {video_path}")


def display_race_summary(config: MasterConfig, video_paths: List[str]):
    """Display a summary of generated races."""
    try:
        from IPython.display import HTML, display

        rows = ""
        for i, path in enumerate(video_paths):
            size_mb = os.path.getsize(path) / (1024 * 1024) if os.path.exists(path) else 0
            rows += f"""
            <tr>
                <td style="padding: 8px;">{i + 1}</td>
                <td style="padding: 8px;">{os.path.basename(path)}</td>
                <td style="padding: 8px;">{size_mb:.1f} MB</td>
                <td style="padding: 8px;">✅</td>
            </tr>
            """

        html = f"""
        <div style="margin: 20px 0;">
            <h2>🏁 Race Generation Summary</h2>
            <table style="border-collapse: collapse; width: 100%; max-width: 600px;">
                <thead>
                    <tr style="background: #333; color: white;">
                        <th style="padding: 8px;">#</th>
                        <th style="padding: 8px;">Filename</th>
                        <th style="padding: 8px;">Size</th>
                        <th style="padding: 8px;">Status</th>
                    </tr>
                </thead>
                <tbody>{rows}</tbody>
            </table>
            <p>📂 Output directory: <code>{config.output_dir}</code></p>
        </div>
        """
        display(HTML(html))
    except ImportError:
        print("\n=== RACE GENERATION SUMMARY ===")
        for i, path in enumerate(video_paths):
            print(f"  {i+1}. {path}")
        print(f"Output: {config.output_dir}")

