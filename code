def main():
    """
    Main entry point for the Brainrot Race Video Generator.
    Generates one race video and displays it.
    """
    print("\n" + "=" * 70)
    print("  🏁 BRAINROT RACE VIDEO GENERATOR 🏁")
    print("  Generating a unique meme character race video...")
    print("=" * 70 + "\n")

    # --- CONFIGURATION ---
    # low_memory_mode=True  → 720×1280, smaller frame cache, fewer particles.
    #   Required for Google Colab Free (≤12 GB RAM).  Set to False on Colab Pro.
    # low_memory_mode=False → full 1080×1920 quality.
    config = MasterConfig(
        low_memory_mode=True,   # ← CRITICAL: keep True on Colab Free
        video=VideoConfig(
            # 720×1280 when low_memory_mode=True (default, Colab-safe).
            # Change to 1080×1920 and set low_memory_mode=False for full
            # quality on Colab Pro or a local machine with ≥8 GB free RAM.
            width=720,
            height=1280,
            fps=30,
            format=VideoFormat.YOUTUBE_SHORTS,
            bitrate="6000k",
        ),
        race=RaceConfig(
            num_characters=10,
            lane_count=10,
            min_race_duration=12.0,
            max_race_duration=13.0,
            countdown_duration=3.0,
            winner_celebration_duration=5.0,
            base_speed=0.006,
            speed_variance=0.004,
        ),
        animation=AnimationConfig(
            sprite_width=120,
            sprite_height=150,
            run_cycle_frames=12,
            celebration_frames=16,
            bounce_amplitude=16.0,
        ),
        scene=SceneConfig(
            crowd_enabled=True,
            particle_count=120,   # halved automatically in low_memory_mode
            track_height_ratio=0.52,
            subscribe_watermark=True,
        ),
        event=EventConfig(
            events_enabled=True,
            bird_flock_chance=0.006,
            camera_shake_chance=0.004,
            speed_boost_chance=0.015,
            confetti_chance=0.01,
        ),
        effects=EffectsConfig(
            speed_trails=True,
            emoji_popups=True,
            who_will_win_text=True,
            overtake_callout=True,
            screen_border_glow=True,
            impact_frames=True,
            fireworks_enabled=True,
            fireworks_count=8,
            confetti_count=300,
        ),
        output_dir="/content/generated_races",
        seed=None,   # None = random seed each run
        batch_size=1,
    )

    # --- GENERATE ---
    orchestrator = RaceOrchestrator(config)

    # Generate a single race (change to generate_batch(N) for batch mode)
    video_path = orchestrator.generate_race(race_index=0)

    # --- DISPLAY ---
    display_video_in_colab(video_path)

    print("\n" + "=" * 70)
    print("  ✅ DONE! Your brainrot race video is ready.")
    print(f"  📁 File: {video_path}")
    print("=" * 70)
    print()
    print("💡 TIPS:")
    print("   • Run again for a completely different race!")
    print("   • Set config.seed = 12345 for reproducible results")
    print("   • Use orchestrator.generate_batch(50) for bulk generation")
    print("   • Modify RaceConfig to change race speed/duration")
    print("   • Add new scene types by subclassing BaseScene")
    print("   • Set low_memory_mode=False for full 1080×1920 on Colab Pro")
    print()

    return video_path


