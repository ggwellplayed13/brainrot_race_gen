class AudioManager:
    """
    Manages audio generation for the race video.
    Generates:
    - Background race music (procedural)
    - Countdown beeps
    - Winner TTS announcement
    """

    def __init__(self, config: MasterConfig):
        self.config = config
        self.temp_dir = FileUtils.ensure_dir(os.path.join(config.output_dir, "temp_audio"))

    def generate_countdown_beep(self, frequency: float = 800, duration_ms: int = 200) -> np.ndarray:
        """Generate a simple beep sound as numpy array."""
        sample_rate = 44100
        t = np.linspace(0, duration_ms / 1000.0, int(sample_rate * duration_ms / 1000.0))
        wave = np.sin(2 * np.pi * frequency * t) * 0.5
        # Envelope
        env = np.ones_like(wave)
        fade_samples = int(len(wave) * 0.1)
        env[:fade_samples] = np.linspace(0, 1, fade_samples)
        env[-fade_samples:] = np.linspace(1, 0, fade_samples)
        return (wave * env * 32767).astype(np.int16)

    def generate_race_audio(
        self, total_duration: float, winner_name: str,
        countdown_duration: float, race_duration: float
    ) -> Optional[str]:
        """
        Generate complete race audio track.
        Returns path to audio file.
        """
        sample_rate = 44100
        total_samples = int(total_duration * sample_rate)
        audio = np.zeros(total_samples, dtype=np.float64)

        # --- Countdown beeps ---
        beep_times = [
            countdown_duration * 0.0,
            countdown_duration * 0.25,
            countdown_duration * 0.50,
            countdown_duration * 0.75,
        ]
        beep_freqs = [600, 600, 600, 1000]
        beep_durations = [150, 150, 150, 300]

        for bt, bf, bd in zip(beep_times, beep_freqs, beep_durations):
            beep = self.generate_countdown_beep(bf, bd)
            start_sample = int(bt * sample_rate)
            end_sample = min(start_sample + len(beep), total_samples)
            beep_float = beep[:end_sample - start_sample].astype(np.float64) / 32767.0
            audio[start_sample:end_sample] += beep_float * 0.6

        # --- Background rhythm during race ---
        race_start_sample = int(countdown_duration * sample_rate)
        race_end_sample = int((countdown_duration + race_duration) * sample_rate)
        race_end_sample = min(race_end_sample, total_samples)

        bpm = 140
        beat_interval = 60.0 / bpm
        beat_sample_interval = int(beat_interval * sample_rate)

        t_array = np.arange(race_end_sample - race_start_sample) / sample_rate

        # Bass drum (low frequency pulse)
        for i in range(int(race_duration / beat_interval)):
            beat_start = i * beat_sample_interval
            if beat_start + 4000 < len(t_array):
                kick_t = np.arange(4000) / sample_rate
                kick = np.sin(2 * np.pi * 80 * kick_t) * np.exp(-kick_t * 20) * 0.3
                audio[race_start_sample + beat_start:
                      race_start_sample + beat_start + len(kick)] += kick

        # Hi-hat (noise burst on offbeats)
        half_beat = beat_sample_interval // 2
        for i in range(int(race_duration / beat_interval) * 2):
            hh_start = i * half_beat
            if hh_start + 1000 < len(t_array):
                hh_t = np.arange(1000) / sample_rate
                hh = np.random.randn(1000) * np.exp(-hh_t * 40) * 0.08
                audio[race_start_sample + hh_start:
                      race_start_sample + hh_start + len(hh)] += hh

        # Rising tension synth
        tension_duration = race_end_sample - race_start_sample
        if tension_duration > 0:
            tension_t = np.arange(tension_duration) / sample_rate
            progress = np.linspace(0, 1, tension_duration)
            freq = 200 + progress * 400
            phase = np.cumsum(freq / sample_rate) * 2 * np.pi
            synth = np.sin(phase) * progress * 0.08
            audio[race_start_sample:race_end_sample] += synth[:race_end_sample - race_start_sample]

        # --- Winner celebration sound ---
        celeb_start = race_end_sample
        if celeb_start + sample_rate < total_samples:
            # Triumphant chord
            celeb_t = np.arange(min(sample_rate, total_samples - celeb_start)) / sample_rate
            chord = (
                np.sin(2 * np.pi * 523 * celeb_t) * 0.15 +  # C5
                np.sin(2 * np.pi * 659 * celeb_t) * 0.12 +  # E5
                np.sin(2 * np.pi * 784 * celeb_t) * 0.10    # G5
            )
            env = np.exp(-celeb_t * 1.5)
            audio[celeb_start:celeb_start + len(chord)] += chord * env

        # --- Winner TTS ---
        tts_path = self._generate_tts(winner_name)
        if tts_path and os.path.exists(tts_path):
            try:
                tts_audio_seg = AudioSegment.from_file(tts_path)
                tts_samples = np.array(tts_audio_seg.get_array_of_samples(), dtype=np.float64)
                if tts_audio_seg.channels == 2:
                    tts_samples = tts_samples[::2]  # Take left channel
                tts_samples = tts_samples / 32768.0 * 0.8

                # Resample if needed
                if tts_audio_seg.frame_rate != sample_rate:
                    ratio = sample_rate / tts_audio_seg.frame_rate
                    new_len = int(len(tts_samples) * ratio)
                    tts_samples = np.interp(
                        np.linspace(0, len(tts_samples) - 1, new_len),
                        np.arange(len(tts_samples)),
                        tts_samples,
                    )

                tts_start = celeb_start + int(0.8 * sample_rate)
                tts_end = min(tts_start + len(tts_samples), total_samples)
                actual_len = tts_end - tts_start
                if actual_len > 0:
                    audio[tts_start:tts_end] += tts_samples[:actual_len]
            except Exception as e:
                log.warning(f"Could not load TTS audio: {e}")

        # Normalize
        max_val = np.max(np.abs(audio))
        if max_val > 0:
            audio = audio / max_val * 0.85

        # Convert to int16
        audio_int16 = (audio * 32767).astype(np.int16)

        # Save to WAV
        audio_path = os.path.join(self.temp_dir, "race_audio.wav")
        import wave as wave_mod
        with wave_mod.open(audio_path, 'w') as wav_file:
            wav_file.setnchannels(1)
            wav_file.setsampwidth(2)
            wav_file.setframerate(sample_rate)
            wav_file.writeframes(audio_int16.tobytes())

        log.info(f"  🔊 Audio generated: {audio_path}")
        return audio_path

    def _generate_tts(self, text: str) -> Optional[str]:
        """Generate TTS audio for winner announcement."""
        try:
            tts_text = f"{text} wins the race!"
            tts = gTTS(text=tts_text, lang='en', slow=False)
            tts_path = os.path.join(self.temp_dir, "winner_tts.mp3")
            tts.save(tts_path)
            return tts_path
        except Exception as e:
            log.warning(f"TTS generation failed: {e}")
            return None

    def cleanup(self):
        """Clean up temporary audio files."""
        FileUtils.cleanup_temp_files(self.temp_dir, "*.wav")
        FileUtils.cleanup_temp_files(self.temp_dir, "*.mp3")

