        title_font = self._get_font(44)
        race_text = "🏁 BRAINROT RACE 🏁"
        bbox = draw.textbbox((0, 0), race_text, font=title_font)
        tw = bbox[2] - bbox[0]
        self._draw_outlined_text(draw, ((w - tw) // 2, 5), race_text, title_font,
