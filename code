                    t = i / max(1, bar_w)
                    r = int(255 * abs(math.sin(t * math.pi)))
                    g = int(200 * abs(math.sin(t * math.pi + 2.09)))
                    b = int(255 * abs(math.sin(t * math.pi + 4.19)))
                    draw.line([(bar_x + i, bar_y + 1), (bar_x + i, bar_y + bar_h - 1)],
